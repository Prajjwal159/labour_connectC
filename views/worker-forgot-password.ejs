<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Worker Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1517022812141-23620dba5c23?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(90deg, rgba(11,49,96,0.56), rgba(12,79,139,0.18), rgba(255,255,255,0.06));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/worker/login" class="btn glass-btn">Back to Login</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center" style="min-height:82vh;">
        <div class="col-lg-6">
            <div class="page-hero-text">
                <div class="tag-chip">Worker Password Reset</div>
                <h1 class="premium-section-title text-white">Recover access to your worker profile.</h1>
                <p>Verify your registered details and set a new password securely.</p>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="frost-card p-4 pretty-form">
                <h3 class="mb-2 text-primary fw-bold">Reset Worker Password</h3>
                <p class="premium-subtitle mb-4">Enter registered email, phone number, and your new password.</p>

                <form action="/worker/forgot-password" method="POST">
                    <div class="mb-3">
                        <label>Registered Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label>Registered Phone</label>
                        <input type="text" name="phone" class="form-control" required>
                    </div>
                    <div class="mb-4">
                        <label>New Password</label>
                        <input type="password" name="newPassword" class="form-control" required>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-blue">Update Password</button>
                        <a href="/worker/login" class="btn pretty-btn-outline">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>