<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('worker_forgot_password_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1517022812141-23620dba5c23?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(90deg, rgba(11,49,96,0.56), rgba(12,79,139,0.18), rgba(255,255,255,0.06));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-primary">ಕನ್ನಡ</a>
            <a href="/worker/login?lang=<%= currentLang %>" class="btn glass-btn"><%= t('back_to_login') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center" style="min-height:82vh;">
        <div class="col-lg-6">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('worker_password_reset') %></div>
                <h1 class="premium-section-title text-white"><%= t('recover_worker_profile') %></h1>
                <p><%= t('recover_worker_profile_text') %></p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="frost-card p-4 pretty-form">
                <h3 class="mb-2 text-primary fw-bold"><%= t('reset_worker_password') %></h3>
                <p class="premium-subtitle mb-4"><%= t('reset_worker_password_text') %></p>

                <form action="/worker/forgot-password?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label><%= t('registered_email') %></label>
                        <input type="email" name="email" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('registered_phone') %></label>
                        <input type="text" name="phone" class="form-control" required>
                    </div>

                    <div class="mb-4">
                        <label><%= t('new_password') %></label>
                        <input type="password" name="newPassword" class="form-control" required>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-blue"><%= t('update_password') %></button>
                        <a href="/worker/login?lang=<%= currentLang %>" class="btn pretty-btn-outline"><%= t('back') %></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>