<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('job_history_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(22,56,28,0.42), rgba(248,251,246,0.95) 48%, rgba(250,252,249,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('job_version_history') %></div>
                <h1 class="premium-section-title text-white"><%= job.job_title %></h1>
                <p><%= t('job_history_text') %></p>
            </div>
        </div>
    </div>

    <% if (versions.length === 0) { %>
        <div class="soft-card p-4">
            <div class="alert alert-warning mb-0"><%= t('no_version_history_found') %></div>
        </div>
    <% } else { %>
        <% versions.forEach((version, index) => { %>
            <div class="soft-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-0"><%= t('version') %> <%= version.version %></h4>
                        <span class="badge bg-dark status-badge mt-2">
                            <%= t('saved_on') %> <%= new Date(version.saved_at).toLocaleString() %>
                        </span>

                        <% if (version.restored_from_version) { %>
                            <div class="alert alert-info mt-2 py-1 px-2 mb-0">
                                🔁 <%= t('restored_from_version') %> <%= version.restored_from_version %>
                            </div>
                        <% } %>
                    </div>

                    <form action="/farmer/restore-job-version/<%= job.id %>/<%= version.version %>?lang=<%= currentLang %>" method="POST">
                        <button type="submit" class="btn pretty-btn-blue">
                            <%= t('restore_this_version') %>
                        </button>
                    </form>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong><%= t('job_title') %>:</strong> <%= version.job_title %></p>
                        <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= version.category %></p>
                        <p class="job-detail-line"><strong><%= t('work_type') %>:</strong> <%= version.work_type %></p>
                        <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= version.location %></p>
                    </div>
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong><%= t('wage') %>:</strong> ₹<%= version.wage %></p>
                        <p class="job-detail-line"><strong><%= t('payment_mode') %>:</strong> <%= version.payment_mode %></p>
                        <p class="job-detail-line"><strong><%= t('start_date') %>:</strong> <%= version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : 'N/A' %></p>
                        <p class="job-detail-line"><strong><%= t('end_date') %>:</strong> <%= version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : 'N/A' %></p>
                    </div>
                </div>

                <div class="mt-3">
                    <p class="job-detail-line"><strong><%= t('description') %>:</strong></p>
                    <div class="alert alert-light mb-0">
                        <%= version.description || t('no_description_provided') %>
                    </div>
                </div>

                <% if (index < versions.length - 1) { 
                    const previous = versions[index + 1];
                %>
                    <div class="mt-4">
                        <h6 class="fw-bold"><%= t('what_changed_from') %> <%= t('version') %> <%= previous.version %> <%= t('to') %> <%= t('version') %> <%= version.version %>:</h6>
                        <ul class="mb-0">
                            <% if (version.job_title !== previous.job_title) { %>
                                <li><%= t('job_title') %> <%= t('changed_from') %> "<%= previous.job_title %>" <%= t('to') %> "<%= version.job_title %>"</li>
                            <% } %>
                            <% if (version.category !== previous.category) { %>
                                <li><%= t('category') %> <%= t('changed_from') %> "<%= previous.category %>" <%= t('to') %> "<%= version.category %>"</li>
                            <% } %>
                            <% if (version.work_type !== previous.work_type) { %>
                                <li><%= t('work_type') %> <%= t('changed_from') %> "<%= previous.work_type %>" <%= t('to') %> "<%= version.work_type %>"</li>
                            <% } %>
                            <% if (version.location !== previous.location) { %>
                                <li><%= t('location') %> <%= t('changed_from') %> "<%= previous.location %>" <%= t('to') %> "<%= version.location %>"</li>
                            <% } %>
                            <% if (Number(version.wage) !== Number(previous.wage)) { %>
                                <li><%= t('wage') %> <%= t('changed_from') %> ₹<%= previous.wage %> <%= t('to') %> ₹<%= version.wage %></li>
                            <% } %>
                            <% if (version.payment_mode !== previous.payment_mode) { %>
                                <li><%= t('payment_mode') %> <%= t('changed_from') %> "<%= previous.payment_mode %>" <%= t('to') %> "<%= version.payment_mode %>"</li>
                            <% } %>
                            <% if ((version.description || '') !== (previous.description || '')) { %>
                                <li><%= t('description_was_updated') %></li>
                            <% } %>
                            <% if (
                                (version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : '') !==
                                (previous.start_date ? new Date(previous.start_date).toISOString().split('T')[0] : '')
                            ) { %>
                                <li><%= t('start_date_changed') %></li>
                            <% } %>
                            <% if (
                                (version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : '') !==
                                (previous.end_date ? new Date(previous.end_date).toISOString().split('T')[0] : '')
                            ) { %>
                                <li><%= t('end_date_changed') %></li>
                            <% } %>
                        </ul>
                    </div>
                <% } else { %>
                    <div class="mt-4 alert alert-secondary mb-0">
                        <%= t('initial_version_text') %>
                    </div>
                <% } %>
            </div>
        <% }) %>
    <% } %>
</div>
</body>
</html>