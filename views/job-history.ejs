<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(22,56,28,0.42), rgba(248,251,246,0.95) 48%, rgba(250,252,249,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/farmer/dashboard" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Job Version History</div>
                <h1 class="premium-section-title text-white"><%= job.job_title %></h1>
                <p>See all saved versions of this job and understand how the posting changed over time.</p>
            </div>
        </div>
    </div>

    <% if (versions.length === 0) { %>
        <div class="soft-card p-4">
            <div class="alert alert-warning mb-0">No version history found for this job.</div>
        </div>
    <% } else { %>
        <% versions.forEach((version, index) => { %>
            <div class="soft-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-0">Version <%= version.version %></h4>
                        <span class="badge bg-dark status-badge mt-2">
                            Saved on <%= new Date(version.saved_at).toLocaleString() %>
                        </span>
                    </div>
                    <form action="/farmer/restore-job-version/<%= job.id %>/<%= version.version %>" method="POST">
                        <button type="submit" class="btn pretty-btn-blue">
                            Restore this version
                        </button>
                    </form>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong>Job Title:</strong> <%= version.job_title %></p>
                        <p class="job-detail-line"><strong>Category:</strong> <%= version.category %></p>
                        <p class="job-detail-line"><strong>Work Type:</strong> <%= version.work_type %></p>
                        <p class="job-detail-line"><strong>Location:</strong> <%= version.location %></p>
                    </div>
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong>Wage:</strong> ₹<%= version.wage %></p>
                        <p class="job-detail-line"><strong>Payment Mode:</strong> <%= version.payment_mode %></p>
                        <p class="job-detail-line"><strong>Start Date:</strong> <%= version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : 'N/A' %></p>
                        <p class="job-detail-line"><strong>End Date:</strong> <%= version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : 'N/A' %></p>
                    </div>
                </div>

                <div class="mt-3">
                    <p class="job-detail-line"><strong>Description:</strong></p>
                    <div class="alert alert-light mb-0">
                        <%= version.description || 'No description provided.' %>
                    </div>
                </div>

                <% if (index < versions.length - 1) { 
                    const previous = versions[index + 1];
                %>
                    <div class="mt-4">
                        <h6 class="fw-bold">What changed from Version <%= previous.version %> to Version <%= version.version %>:</h6>
                        <ul class="mb-0">
                            <% if (version.job_title !== previous.job_title) { %>
                                <li>Job Title changed from "<%= previous.job_title %>" to "<%= version.job_title %>"</li>
                            <% } %>
                            <% if (version.category !== previous.category) { %>
                                <li>Category changed from "<%= previous.category %>" to "<%= version.category %>"</li>
                            <% } %>
                            <% if (version.work_type !== previous.work_type) { %>
                                <li>Work Type changed from "<%= previous.work_type %>" to "<%= version.work_type %>"</li>
                            <% } %>
                            <% if (version.location !== previous.location) { %>
                                <li>Location changed from "<%= previous.location %>" to "<%= version.location %>"</li>
                            <% } %>
                            <% if (Number(version.wage) !== Number(previous.wage)) { %>
                                <li>Wage changed from ₹<%= previous.wage %> to ₹<%= version.wage %></li>
                            <% } %>
                            <% if (version.payment_mode !== previous.payment_mode) { %>
                                <li>Payment Mode changed from "<%= previous.payment_mode %>" to "<%= version.payment_mode %>"</li>
                            <% } %>
                            <% if ((version.description || '') !== (previous.description || '')) { %>
                                <li>Description was updated</li>
                            <% } %>
                            <% if (
                                (version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : '') !==
                                (previous.start_date ? new Date(previous.start_date).toISOString().split('T')[0] : '')
                            ) { %>
                                <li>Start Date changed</li>
                            <% } %>
                            <% if (
                                (version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : '') !==
                                (previous.end_date ? new Date(previous.end_date).toISOString().split('T')[0] : '')
                            ) { %>
                                <li>End Date changed</li>
                            <% } %>
                        </ul>
                    </div>
                <% } else { %>
                    <div class="mt-4 alert alert-secondary mb-0">
                        This is the initial version of the job.
                    </div>
                <% } %>
            </div>
        <% }) %>
    <% } %>
</div>
</body>
</html>