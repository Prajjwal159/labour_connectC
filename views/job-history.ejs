<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('job_history_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell jobs-ui-page">
<%
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: `/farmer/jobs?lang=${currentLang}`, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
  const navActions = [
    { href: `?lang=${currentLang === 'en' ? 'kn' : 'en'}`, label: currentLang === 'en' ? 'EN' : 'KN', className: 'nr-nav-btn nr-nav-btn-ghost' },
    { href: `/farmer/dashboard?lang=${currentLang}`, label: 'Dashboard', className: 'nr-nav-btn nr-nav-btn-primary' }
  ];
%>
<%- include('partials/unified-navbar', { navId: 'landingNav', fixed: false, active: 'jobs', links: navLinks, actions: navActions }) %>

<main class="container jobs-page-wrap">
    <section class="jobs-hero-card">
        <h1><%= job.job_title %></h1>
        <p><%= t('job_history_text') %></p>
    </section>

    <% if (versions.length === 0) { %>
        <div class="jobs-empty"><%= t('no_version_history_found') %></div>
    <% } else { %>
        <% versions.forEach((version, index) => { %>
            <article class="jobs-version-card">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <div>
                        <h4 class="mb-0"><%= t('version') %> <%= version.version %></h4>
                        <span class="badge bg-dark status-badge mt-2"><%= t('saved_on') %> <%= new Date(version.saved_at).toLocaleString() %></span>
                        <% if (version.restored_from_version) { %>
                            <div class="alert alert-info mt-2 py-1 px-2 mb-0"><%= t('restored_from_version') %> <%= version.restored_from_version %></div>
                        <% } %>
                    </div>
                    <form action="/farmer/restore-job-version/<%= job.id %>/<%= version.version %>?lang=<%= currentLang %>" method="POST">
                        <button type="submit" class="btn pretty-btn-blue"><%= t('restore_this_version') %></button>
                    </form>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong><%= t('job_title') %>:</strong> <%= version.job_title %></p>
                        <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= version.category %></p>
                        <p class="job-detail-line"><strong><%= t('work_type') %>:</strong> <%= version.work_type %></p>
                        <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= version.location %></p>
                    </div>
                    <div class="col-md-6">
                        <p class="job-detail-line"><strong><%= t('wage') %>:</strong> &#8377;<%= version.wage %></p>
                        <p class="job-detail-line"><strong><%= t('payment_mode') %>:</strong> <%= version.payment_mode %></p>
                        <p class="job-detail-line"><strong><%= t('start_date') %>:</strong> <%= version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : 'N/A' %></p>
                        <p class="job-detail-line"><strong><%= t('end_date') %>:</strong> <%= version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : 'N/A' %></p>
                    </div>
                </div>
                <div class="alert alert-light mt-3"><strong><%= t('description') %>:</strong> <%= version.description || t('no_description_provided') %></div>

                <% if (index < versions.length - 1) { const previous = versions[index + 1]; %>
                    <div class="mt-3">
                        <h6 class="fw-bold"><%= t('what_changed_from') %> <%= t('version') %> <%= previous.version %> <%= t('to') %> <%= t('version') %> <%= version.version %>:</h6>
                        <ul class="mb-0">
                            <% if (version.job_title !== previous.job_title) { %><li><%= t('job_title') %> <%= t('changed_from') %> "<%= previous.job_title %>" <%= t('to') %> "<%= version.job_title %>"</li><% } %>
                            <% if (version.category !== previous.category) { %><li><%= t('category') %> <%= t('changed_from') %> "<%= previous.category %>" <%= t('to') %> "<%= version.category %>"</li><% } %>
                            <% if (version.work_type !== previous.work_type) { %><li><%= t('work_type') %> <%= t('changed_from') %> "<%= previous.work_type %>" <%= t('to') %> "<%= version.work_type %>"</li><% } %>
                            <% if (version.location !== previous.location) { %><li><%= t('location') %> <%= t('changed_from') %> "<%= previous.location %>" <%= t('to') %> "<%= version.location %>"</li><% } %>
                            <% if (Number(version.wage) !== Number(previous.wage)) { %><li><%= t('wage') %> <%= t('changed_from') %> &#8377;<%= previous.wage %> <%= t('to') %> &#8377;<%= version.wage %></li><% } %>
                            <% if (version.payment_mode !== previous.payment_mode) { %><li><%= t('payment_mode') %> <%= t('changed_from') %> "<%= previous.payment_mode %>" <%= t('to') %> "<%= version.payment_mode %>"</li><% } %>
                            <% if ((version.description || '') !== (previous.description || '')) { %><li><%= t('description_was_updated') %></li><% } %>
                            <% if ((version.start_date ? new Date(version.start_date).toISOString().split('T')[0] : '') !== (previous.start_date ? new Date(previous.start_date).toISOString().split('T')[0] : '')) { %><li><%= t('start_date_changed') %></li><% } %>
                            <% if ((version.end_date ? new Date(version.end_date).toISOString().split('T')[0] : '') !== (previous.end_date ? new Date(previous.end_date).toISOString().split('T')[0] : '')) { %><li><%= t('end_date_changed') %></li><% } %>
                        </ul>
                    </div>
                <% } else { %>
                    <div class="alert alert-secondary mt-3 mb-0"><%= t('initial_version_text') %></div>
                <% } %>
            </article>
        <% }) %>
    <% } %>
</main>

<footer class="platform-footer"><div class="row g-4"><div class="col-lg-5"><a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a><p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p></div><div class="col-6 col-lg-2"><div class="footer-col-title">Platform</div><div class="d-grid gap-2 mt-2"><a href="/marketplace?lang=<%= currentLang %>">Marketplace</a><a href="/farmer/dashboard?lang=<%= currentLang %>">Jobs</a><a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a></div></div><div class="col-6 col-lg-2"><div class="footer-col-title">Support</div><div class="d-grid gap-2 mt-2"><a href="/?lang=<%= currentLang %>">Home</a><a href="/farmer/login?lang=<%= currentLang %>">Login</a></div></div><div class="col-12 col-lg-3"><div class="footer-col-title">Legal</div><div class="d-grid gap-2 mt-2"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a></div></div></div><div class="footer-bottom">© 2024 Namma Raitha Digital Ecosystem.</div></footer>
</body>
</html>

