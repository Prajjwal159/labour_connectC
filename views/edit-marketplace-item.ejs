<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Marketplace Item</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(20,74,36,0.50), rgba(245,249,244,0.95) 48%, rgba(248,251,247,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2">
            <a href="/marketplace?lang=<%= currentLang %>" class="btn glass-btn">Marketplace</a>
            <a href="/farmer/my-marketplace-items?lang=<%= currentLang %>" class="btn glass-btn">My Items</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:85vh;">
        <div class="col-lg-7">
            <div class="frost-card p-5">
                <h2 class="text-success fw-bold mb-3">Edit Marketplace Item</h2>
                <p class="premium-subtitle mb-4">Update your product or equipment details.</p>

                <form action="/farmer/edit-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label>Item Title</label>
                        <input type="text" name="item_title" class="form-control" value="<%= item.item_title %>" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Category</label>
                            <select name="category" class="form-select" required>
                                <option value="Vegetables" <%= item.category === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
                                <option value="Fruits" <%= item.category === 'Fruits' ? 'selected' : '' %>>Fruits</option>
                                <option value="Seeds" <%= item.category === 'Seeds' ? 'selected' : '' %>>Seeds</option>
                                <option value="Fertilizers" <%= item.category === 'Fertilizers' ? 'selected' : '' %>>Fertilizers</option>
                                <option value="Tools" <%= item.category === 'Tools' ? 'selected' : '' %>>Tools</option>
                                <option value="Equipment" <%= item.category === 'Equipment' ? 'selected' : '' %>>Equipment</option>
                                <option value="Other" <%= item.category === 'Other' ? 'selected' : '' %>>Other</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Item Type</label>
                            <select name="item_type" class="form-select" required>
                                <option value="Sell" <%= item.item_type === 'Sell' ? 'selected' : '' %>>Sell</option>
                                <option value="Rent" <%= item.item_type === 'Rent' ? 'selected' : '' %>>Rent</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Description</label>
                        <textarea name="description" class="form-control" rows="4"><%= item.description || '' %></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Price</label>
                            <input type="number" step="0.01" name="price" class="form-control" value="<%= item.price %>" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Location / Village</label>
                            <input type="text" name="location" class="form-control" value="<%= item.location || '' %>">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Contact Phone</label>
                        <input type="text" name="contact_phone" class="form-control" value="<%= item.contact_phone || '' %>" required>
                    </div>

                    <div class="mb-4">
                        <label>Image URL</label>
                        <input type="text" name="image_url" class="form-control" value="<%= item.image_url || '' %>">
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green">Update Item</button>
                        <a href="/farmer/my-marketplace-items?lang=<%= currentLang %>" class="btn pretty-btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>