<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2">
            <a href="/farmer/post-job" class="btn glass-btn">+ Post Job</a>
            <a href="/logout" class="btn glass-btn-outline">Logout</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <div class="page-hero-text">
                <div class="tag-chip">Farmer Control Center</div>
                <h1 class="premium-section-title text-white">Welcome, <%= farmer.full_name %></h1>
                <p>Monitor job postings, review applications, and organize rural hiring with a clean digital workflow.</p>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="visual-card" style="height:260px;">
                <img src="https://images.unsplash.com/photo-1523741543316-beb7fc7023d8?auto=format&fit=crop&w=1200&q=80" alt="Farmer field">
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4 dashboard-grid-gap">
        <div class="col-md-4">
            <div class="metric-card metric-green">
                <h5>Total Jobs Posted</h5>
                <h2><%= jobs.length %></h2>
                <p class="mb-0">Keep track of all your active and past job opportunities.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-blue">
                <h5>Village</h5>
                <h2 style="font-size:1.5rem;"><%= farmer.village || 'N/A' %></h2>
                <p class="mb-0">Primary location linked to your hiring profile.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-gold">
                <h5>Contact</h5>
                <h2 style="font-size:1.4rem;"><%= farmer.phone %></h2>
                <p class="mb-0">Use this number for worker communication and support.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="soft-card p-4 full-height-card">
                <h4 class="mb-3">Farmer Profile</h4>
                <p class="job-detail-line"><strong>Name:</strong> <%= farmer.full_name %></p>
                <p class="job-detail-line"><strong>Email:</strong> <%= farmer.email %></p>
                <p class="job-detail-line"><strong>Phone:</strong> <%= farmer.phone %></p>
                <p class="job-detail-line"><strong>Village:</strong> <%= farmer.village || 'N/A' %></p>

                <div class="mt-3">
                    <span class="action-pill">Hiring</span>
                    <span class="action-pill gold">Management</span>
                    <span class="action-pill blue">Farm Jobs</span>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="soft-card p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h4 class="mb-0">My Posted Jobs</h4>
                    <a href="/farmer/post-job" class="btn pretty-btn-green">Create New Job</a>
                </div>

                <% if (jobs.length === 0) { %>
                    <div class="alert alert-warning mb-0">You have not posted any jobs yet.</div>
                <% } else { %>
                    <div class="row">
                        <% jobs.forEach(job => { %>
                            <div class="col-md-6 mb-4">
                                <div class="soft-card p-3 full-height-card">
                                    <h5 class="mb-2"><%= job.job_title %></h5>
                                    <p class="job-detail-line"><strong>Category:</strong> <%= job.category %></p>
                                    <p class="job-detail-line"><strong>Work Type:</strong> <%= job.work_type %></p>
                                    <p class="job-detail-line"><strong>Location:</strong> <%= job.location %></p>
                                    <p class="job-detail-line"><strong>Wage:</strong> ₹<%= job.wage %></p>
                                    <p class="job-detail-line">
                                        <strong>Status:</strong>
                                        <% if (job.status === 'Open') { %>
                                            <span class="badge bg-success status-badge">Open</span>
                                            <% } else { %>
                                                <span class="badge bg-danger status-badge">Closed</span>
                                                <% } %>
                                    </p>
                                    <div class="d-flex gap-2 mt-2 flex-wrap">
                                        <a href="/farmer/edit-job/<%= job.id %>" class="btn pretty-btn-green flex-fill">
                                            Edit Job
                                        </a>
                                        <a href="/farmer/job-applications/<%= job.id %>" class="btn pretty-btn-outline flex-fill">
                                            Applications
                                        </a>
                                        <a href="/farmer/job-history/<%= job.id %>" class="btn pretty-btn-blue flex-fill">
                                            History
                                        </a>
                                        <% if (job.status === 'Open') { %>
                                            <form action="/farmer/close-job/<%= job.id %>" method="POST" class="flex-fill"
                                                onsubmit="return confirm('Are you sure you want to close this job? Workers will no longer see it.');">
                                                <button type="submit" class="btn pretty-btn-red w-100">
                                                    Close Job
                                                </button>
                                            </form>
                                            <% } else { %>
                                                <form action="/farmer/reopen-job/<%= job.id %>" method="POST" class="flex-fill"
                                                    onsubmit="return confirm('Do you want to reopen this job for workers?');">
                                                    <button type="submit" class="btn pretty-btn-green w-100">
                                                        Reopen Job
                                                    </button>
                                                </form>
                                                <% } %>
                                                <form action="/farmer/delete-job/<%= job.id %>" method="POST" class="flex-fill"
                                                    onsubmit="return confirm('Are you sure you want to permanently delete this job? This will remove applications and version history too.');">
                                                    <button type="submit" class="btn pretty-btn-outline flex-fill">
                                                        Delete Job
                                                    </button>
                                                </form>
                                            </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
</body>
</html>