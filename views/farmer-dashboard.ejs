<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_dashboard') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/farmer/post-job?lang=<%= currentLang %>" class="btn glass-btn">+ <%= t('post_job') %></a>
            <a href="/logout?lang=<%= currentLang %>" class="btn glass-btn-outline"><%= t('logout') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('farmer_control_center') %></div>
                <h1 class="premium-section-title text-white"><%= t('welcome') %>, <%= farmer.full_name %></h1>
                <p><%= t('farmer_dashboard_text') %></p>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="visual-card" style="height:260px;">
                <img src="https://images.unsplash.com/photo-1523741543316-beb7fc7023d8?auto=format&fit=crop&w=1200&q=80" alt="Farmer field">
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4 dashboard-grid-gap">
        <div class="col-md-4">
            <div class="metric-card metric-green">
                <h5><%= t('total_jobs_posted') %></h5>
                <h2><%= jobs.length %></h2>
                <p class="mb-0"><%= t('total_jobs_posted_text') %></p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-blue">
                <h5><%= t('village') %></h5>
                <h2 style="font-size:1.5rem;"><%= farmer.village || 'N/A' %></h2>
                <p class="mb-0"><%= t('village_text') %></p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-gold">
                <h5><%= t('contact') %></h5>
                <h2 style="font-size:1.4rem;"><%= farmer.phone %></h2>
                <p class="mb-0"><%= t('contact_text') %></p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="soft-card p-4 full-height-card">
                <h4 class="mb-3"><%= t('farmer_profile') %></h4>
                <p class="job-detail-line"><strong><%= t('full_name') %>:</strong> <%= farmer.full_name %></p>
                <p class="job-detail-line"><strong><%= t('email') %>:</strong> <%= farmer.email %></p>
                <p class="job-detail-line"><strong><%= t('phone') %>:</strong> <%= farmer.phone %></p>
                <p class="job-detail-line"><strong><%= t('village') %>:</strong> <%= farmer.village || 'N/A' %></p>

                <div class="mt-3">
                    <span class="action-pill"><%= t('hiring') %></span>
                    <span class="action-pill gold"><%= t('management') %></span>
                    <span class="action-pill blue"><%= t('farm_jobs') %></span>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="soft-card p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h4 class="mb-0"><%= t('my_posted_jobs') %></h4>
                    <a href="/farmer/post-job?lang=<%= currentLang %>" class="btn pretty-btn-green"><%= t('create_new_job') %></a>
                </div>

                <% if (jobs.length === 0) { %>
                    <div class="alert alert-warning mb-0"><%= t('no_jobs_posted') %></div>
                <% } else { %>
                    <div class="row">
                        <% jobs.forEach(job => { %>
                            <div class="col-md-6 mb-4">
                                <div class="soft-card p-3 full-height-card">
                                    <h5 class="mb-2"><%= job.job_title %></h5>
                                    <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= job.category %></p>
                                    <p class="job-detail-line"><strong><%= t('work_type') %>:</strong> <%= job.work_type %></p>
                                    <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= job.location %></p>
                                    <p class="job-detail-line"><strong><%= t('wage') %>:</strong> ₹<%= job.wage %></p>
                                    <p class="job-detail-line"><strong>Applications:</strong> <%= job.applied_count || 0 %> / <%= job.workers_required %> workers</p>
                                    <p class="job-detail-line"><strong><%= t('workers_required') %>:</strong> <%= job.workers_required %></p>
                                    <p class="job-detail-line">
                                        <strong><%= t('status') %>:</strong>
                                        <% if (job.status === 'Open') { %>
                                            <span class="badge bg-success status-badge"><%= t('open') %></span>
                                        <% } else { %>
                                            <span class="badge bg-danger status-badge"><%= t('closed') %></span>
                                        <% } %>
                                    </p>

                                    <div class="d-flex gap-2 mt-2 flex-wrap">
                                        <a href="/farmer/edit-job/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-green flex-fill">
                                            <%= t('edit_job') %>
                                        </a>

                                        <a href="/farmer/job-applications/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-outline flex-fill">
                                            <%= t('applications') %>
                                        </a>

                                        <a href="/farmer/job-history/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-blue flex-fill">
                                            <%= t('history') %>
                                        </a>
                                        <% if (job.status === 'Open') { %>
                                            <form action="/farmer/close-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill"onsubmit='return confirm("<%= t("confirm_close_job") %>");'>
                                                <button type="submit" class="btn pretty-btn-red w-100">
                                                    <%= t('close_job') %>
                                                </button>
                                            </form>
                                            <% } else { %>
                                                <form action="/farmer/reopen-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill"onsubmit='return confirm("<%= t("confirm_reopen_job") %>");'>
                                                    <button type="submit" class="btn pretty-btn-green w-100">
                                                        <%= t('reopen_job') %>
                                                    </button>
                                                </form>
                                                <% } %>
                                                <form action="/farmer/delete-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill"onsubmit='return confirm("<%= t("confirm_delete_job") %>");'>
                                                    <button type="submit" class="btn pretty-btn-outline flex-fill">
                                                        <%= t('delete_job') %>
                                                    </button>
                                                </form>  
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
</body>
</html>