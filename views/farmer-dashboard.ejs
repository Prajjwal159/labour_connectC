<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_dashboard') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell dashboard-v3 farmer-dashboard-v3">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(10,44,82,0.5), rgba(239,246,255,0.94) 50%, rgba(245,249,255,1));"></div>
<%
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: `/farmer/jobs?lang=${currentLang}`, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
%>
<%- include('partials/unified-navbar', { fixed: false, active: 'dashboard', links: navLinks }) %>

<main class="container page-content dash-main-wrap">
  <% if (subscriptionExpired) { %>
    <div class="dash-inline-alert danger">
      <div>
        <strong>Subscription Expired.</strong> Your premium actions are limited until renewal.
      </div>
      <a href="/farmer/renew-subscription?lang=<%= currentLang %>" class="btn btn-sm btn-danger">Renew Now</a>
    </div>
  <% } %>

  <% if (subscriptionWarning && subscriptionWarning.type === "warning") { %>
    <div class="dash-inline-alert warning">
      <div>
        <strong>Subscription Warning:</strong> <%= subscriptionWarning.message %>
      </div>
      <a href="/farmer/renew-subscription?lang=<%= currentLang %>" class="btn btn-sm btn-warning">Renew Now</a>
    </div>
  <% } %>

  <section class="dash-hero-card">
    <div class="dash-hero-copy">
      <div class="dash-chip"><%= t('farmer_control_center') %></div>
      <h1><%= t('welcome') %>, <%= farmer.full_name %></h1>
      <p><%= t('farmer_dashboard_text') %></p>
    </div>
    <div class="dash-hero-actions">
      <% if (subscriptionExpired) { %>
        <button class="btn pretty-btn-green w-100" disabled title="Subscription expired"><%= t('post_job') %></button>
      <% } else { %>
        <a href="/farmer/post-job?lang=<%= currentLang %>" class="btn pretty-btn-green w-100"><%= t('post_job') %></a>
      <% } %>

      <% if (subscriptionExpired) { %>
        <button class="btn pretty-btn-outline w-100" disabled title="Subscription expired">+ Post Item</button>
      <% } else { %>
        <a href="/farmer/post-marketplace-item?lang=<%= currentLang %>" class="btn pretty-btn-outline w-100">+ Post Item</a>
      <% } %>

      <a href="/farmer/my-marketplace-items?lang=<%= currentLang %>" class="btn pretty-btn-blue w-100">My Items</a>
    </div>
  </section>

  <section class="dash-metric-grid">
    <article class="dash-metric-card">
      <p class="label"><%= t('total_jobs_posted') %></p>
      <h3><%= jobs.length %></h3>
      <p class="hint"><%= t('total_jobs_posted_text') %></p>
    </article>
    <article class="dash-metric-card">
      <p class="label"><%= t('village') %></p>
      <h3><%= farmer.village || 'N/A' %></h3>
      <p class="hint"><%= t('village_text') %></p>
    </article>
    <article class="dash-metric-card">
      <p class="label"><%= t('contact') %></p>
      <h3><%= farmer.phone %></h3>
      <p class="hint"><%= t('contact_text') %></p>
    </article>
    <article class="dash-metric-card">
      <p class="label">Marketplace Items</p>
      <h3><%= marketplaceSummary.total_items || 0 %></h3>
      <p class="hint">Total products, tools, and equipment listed.</p>
    </article>
    <article class="dash-metric-card">
      <p class="label">Available Items</p>
      <h3><%= marketplaceSummary.available_items || 0 %></h3>
      <p class="hint">Items currently visible in the public marketplace.</p>
    </article>
    <article class="dash-metric-card">
      <p class="label">Sold Items</p>
      <h3><%= marketplaceSummary.sold_items || 0 %></h3>
      <p class="hint">Items already marked as sold or unavailable.</p>
    </article>
  </section>

  <section class="row g-4 align-items-start">
    <div class="col-xl-8">
      <div class="soft-card p-4 dash-panel mb-4">
        <div class="dash-panel-head">
          <h4 class="mb-0"><%= t('my_posted_jobs') %></h4>
          <a href="/farmer/post-job?lang=<%= currentLang %>" class="btn pretty-btn-green btn-sm"><%= t('create_new_job') %></a>
        </div>

        <% if (jobs.length === 0) { %>
          <div class="alert alert-warning mb-0"><%= t('no_jobs_posted') %></div>
        <% } else { %>
          <div class="row g-3">
            <% jobs.forEach(job => { %>
              <div class="col-md-6">
                <article class="dash-job-card">
                  <h5><%= job.job_title %></h5>
                  <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= job.category %></p>
                  <p class="job-detail-line"><strong><%= t('work_type') %>:</strong> <%= job.work_type %></p>
                  <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= job.location %></p>
                  <p class="job-detail-line"><strong><%= t('wage') %>:</strong> &#8377;<%= job.wage %></p>
                  <p class="job-detail-line"><strong>Applications:</strong> <%= job.applied_count || 0 %> / <%= job.workers_required %> workers</p>
                  <p class="job-detail-line"><strong><%= t('workers_required') %>:</strong> <%= job.workers_required %></p>
                  <p class="job-detail-line mb-3">
                    <strong><%= t('status') %>:</strong>
                    <% if (job.status === 'Open') { %>
                      <span class="badge bg-success status-badge"><%= t('open') %></span>
                    <% } else { %>
                      <span class="badge bg-danger status-badge"><%= t('closed') %></span>
                    <% } %>
                  </p>

                  <div class="d-flex gap-2 flex-wrap">
                    <a href="/farmer/edit-job/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-green flex-fill"><%= t('edit_job') %></a>
                    <a href="/farmer/job-applications/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-outline flex-fill"><%= t('applications') %></a>
                    <a href="/farmer/job-history/<%= job.id %>?lang=<%= currentLang %>" class="btn pretty-btn-blue flex-fill"><%= t('history') %></a>

                    <% if (job.status === 'Open') { %>
                      <form action="/farmer/close-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill" onsubmit='return confirm("<%= t("confirm_close_job") %>");'>
                        <button type="submit" class="btn pretty-btn-red w-100"><%= t('close_job') %></button>
                      </form>
                    <% } else { %>
                      <form action="/farmer/reopen-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill" onsubmit='return confirm("<%= t("confirm_reopen_job") %>");'>
                        <button type="submit" class="btn pretty-btn-green w-100"><%= t('reopen_job') %></button>
                      </form>
                    <% } %>

                    <form action="/farmer/delete-job/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="flex-fill" onsubmit='return confirm("<%= t("confirm_delete_job") %>");'>
                      <button type="submit" class="btn pretty-btn-outline w-100"><%= t('delete_job') %></button>
                    </form>
                  </div>
                </article>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="soft-card p-4 dash-panel">
        <div class="dash-panel-head">
          <h4 class="mb-0">Recent Marketplace Items</h4>
          <a href="/farmer/my-marketplace-items?lang=<%= currentLang %>" class="btn pretty-btn-outline btn-sm">View All Items</a>
        </div>

        <% if (!recentMarketplaceItems || recentMarketplaceItems.length === 0) { %>
          <div class="alert alert-warning mb-0">You have not posted any marketplace items yet.</div>
        <% } else { %>
          <div class="row g-3">
            <% recentMarketplaceItems.forEach(item => { %>
              <div class="col-sm-6">
                <article class="dash-market-item">
                  <% if (item.image_url) { %>
                    <img src="<%= item.image_url %>" alt="<%= item.item_title %>" class="img-fluid rounded mb-3 dash-item-image">
                  <% } else { %>
                    <div class="dash-item-image dash-item-empty mb-3">No Image</div>
                  <% } %>

                  <h6 class="mb-1"><%= item.item_title %></h6>
                  <div class="mb-2">
                    <span class="action-pill"><%= item.category %></span>
                    <span class="action-pill blue"><%= item.item_type %></span>
                  </div>
                  <p class="job-detail-line"><strong>Price:</strong> &#8377;<%= item.price %></p>
                  <p class="job-detail-line"><strong>Status:</strong> <%= item.status %></p>
                  <p class="job-detail-line"><strong>Location:</strong> <%= item.location || 'N/A' %></p>

                  <div class="d-flex gap-2 mt-3">
                    <a href="/farmer/edit-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" class="btn pretty-btn-green w-100">Edit</a>
                    <a href="/marketplace/item/<%= item.id %>?lang=<%= currentLang %>" class="btn pretty-btn-blue w-100">View</a>
                  </div>
                </article>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="soft-card p-4 dash-panel mb-4">
        <h4 class="mb-3"><%= t('farmer_profile') %></h4>
        <p class="job-detail-line"><strong><%= t('full_name') %>:</strong> <%= farmer.full_name %></p>
        <p class="job-detail-line"><strong><%= t('email') %>:</strong> <%= farmer.email %></p>
        <p class="job-detail-line"><strong><%= t('phone') %>:</strong> <%= farmer.phone %></p>
        <p class="job-detail-line"><strong><%= t('village') %>:</strong> <%= farmer.village || 'N/A' %></p>
        <div class="mt-3">
          <span class="action-pill"><%= t('hiring') %></span>
          <span class="action-pill gold"><%= t('management') %></span>
          <span class="action-pill blue"><%= t('farm_jobs') %></span>
        </div>
      </div>

      <div class="soft-card p-4 dash-panel mb-4">
        <h4 class="mb-3">Subscription Details</h4>
        <p class="job-detail-line"><strong>Plan:</strong> <%= farmer.subscription_plan || 'N/A' %></p>
        <p class="job-detail-line">
          <strong>Status:</strong>
          <% if (farmer.subscription_status === 'Paid') { %>
            <span class="badge bg-success status-badge">Active</span>
          <% } else { %>
            <span class="badge bg-danger status-badge"><%= farmer.subscription_status || 'N/A' %></span>
          <% } %>
        </p>
        <p class="job-detail-line"><strong>Start Date:</strong> <%= farmer.subscription_start_date ? new Date(farmer.subscription_start_date).toISOString().split('T')[0] : 'N/A' %></p>
        <p class="job-detail-line"><strong>Expiry Date:</strong> <%= farmer.subscription_end_date ? new Date(farmer.subscription_end_date).toISOString().split('T')[0] : 'N/A' %></p>
        <p class="job-detail-line"><strong>Amount:</strong> &#8377;<%= farmer.subscription_amount || 'N/A' %></p>
        <p class="job-detail-line mb-0"><strong>Duration:</strong> <%= farmer.subscription_months || 'N/A' %> months</p>
      </div>

      <div class="soft-card p-4 dash-panel">
        <h4 class="mb-3">Activity Alerts</h4>
        <% if (subscriptionExpired) { %>
          <p class="job-detail-line mb-3">Your subscription has expired. Renew to restore posting and management actions.</p>
          <a href="/farmer/renew-subscription?lang=<%= currentLang %>" class="btn pretty-btn-green w-100">Renew Subscription</a>
        <% } else if (subscriptionWarning) { %>
          <p class="job-detail-line mb-3"><%= subscriptionWarning.message %></p>
          <a href="/farmer/renew-subscription?lang=<%= currentLang %>" class="btn pretty-btn-outline w-100">Renew Soon</a>
        <% } else { %>
          <p class="job-detail-line mb-2">Subscription is active and all farmer tools are available.</p>
          <p class="job-detail-line mb-0">Continue posting jobs and marketplace items to increase outreach.</p>
        <% } %>
      </div>
    </div>
  </section>
</main>

<footer class="platform-footer">
  <div class="row g-4">
    <div class="col-lg-5">
      <a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
      <p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Platform</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/marketplace?lang=<%= currentLang %>">Marketplace</a>
        <a href="/farmer/jobs?lang=<%= currentLang %>">Jobs</a>
        <a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Support</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/?lang=<%= currentLang %>">Home</a>
        <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
      </div>
    </div>
    <div class="col-12 col-lg-3">
      <div class="footer-col-title">Legal</div>
      <div class="d-grid gap-2 mt-2">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">(c) 2024 Namma Raitha Digital Ecosystem.</div>
</footer>

<%- include('partials/micro-interactions') %>
</body>
</html>
