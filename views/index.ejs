<body class="landing-body">

<!-- ── Opening Animation Curtain ───────────────────────────────── -->
<div id="nr-intro" aria-hidden="true">
  <div id="nr-intro-text">
    <svg id="nr-intro-leaf" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#b7d9bf" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><path d="M12 22v-9"/><path d="M12 17l-4-4"/><path d="M12 13l4-4"/></svg>
    <span id="nr-intro-typed"></span><span id="nr-intro-cursor">|</span>
  </div>
</div>
<style>
#nr-intro {
  position: fixed; inset: 0; z-index: 100000;
  background: #0d2414;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
  transition: transform 0.72s cubic-bezier(0.76,0,0.24,1);
}
#nr-intro.nr-intro-out {
  transform: translateY(-100%);
}
#nr-intro-text {
  display: flex; align-items: center; gap: 14px;
  font-family: 'Sora', 'Inter', sans-serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 700;
  color: #e8f5eb;
  letter-spacing: -0.02em;
}
#nr-intro-cursor {
  color: #4A6752;
  animation: nr-blink 0.7s step-start infinite;
}
@keyframes nr-blink { 50% { opacity: 0; } }
</style>
<script>
(function(){
  var intro = document.getElementById('nr-intro');
  if(!intro) return;
  // Task 1: Only show once per session — language toggle won't retrigger
  if(sessionStorage.getItem('nr_intro_seen')) {
    intro.style.display='none';
    return;
  }
  var typed = document.getElementById('nr-intro-typed');
  var text = 'Namma Raitha', i = 0;
  document.body.style.overflow = 'hidden';
  function typeChar() {
    if(i < text.length) {
      typed.textContent += text[i++];
      setTimeout(typeChar, i===1?300:58);
    } else {
      setTimeout(function(){
        intro.classList.add('nr-intro-out');
        document.body.style.overflow = '';
        sessionStorage.setItem('nr_intro_seen','1');
        setTimeout(function(){ intro.style.display='none'; }, 750);
      }, 520);
    }
  }
  setTimeout(typeChar, 180);
})();
</script>

<style>
/* Task 1: Hero entry animations — start AFTER the intro curtain is gone */
/* Default: first visit, intro plays ~2.1s before reveal */
:root { --nr-hero-base: 2.15s; }
.hero-anim-chip { animation: nr-hero-in 0.6s cubic-bezier(0.22,1,0.36,1) calc(var(--nr-hero-base) + 0.00s) both; }
.hero-anim-h1   { animation: nr-hero-in 0.7s cubic-bezier(0.22,1,0.36,1) calc(var(--nr-hero-base) + 0.14s) both; }
.hero-anim-sub  { animation: nr-hero-in 0.7s cubic-bezier(0.22,1,0.36,1) calc(var(--nr-hero-base) + 0.27s) both; }
.hero-anim-cta  { animation: nr-hero-in 0.7s cubic-bezier(0.22,1,0.36,1) calc(var(--nr-hero-base) + 0.40s) both; }
@keyframes nr-hero-in {
  from { opacity:0; transform: translateY(24px); }
  to   { opacity:1; transform: none; }
}
/* Task 2: Card bounce-in then smooth float — delays timed so float begins exactly when bounce ends */
/* bounce_start + 0.8s_duration = float_start */
.fc-bounce.nr-float-1 { opacity:0; animation: nr-fc-bounce 0.8s cubic-bezier(0.34,1.56,0.64,1) calc(var(--nr-hero-base) + 0.30s) forwards, float 6s ease-in-out calc(var(--nr-hero-base) + 1.10s) infinite; }
.fc-bounce.nr-float-2 { opacity:0; animation: nr-fc-bounce 0.8s cubic-bezier(0.34,1.56,0.64,1) calc(var(--nr-hero-base) + 0.50s) forwards, float 5s ease-in-out calc(var(--nr-hero-base) + 1.30s) infinite reverse; }
.fc-bounce.nr-float-3 { opacity:0; animation: nr-fc-bounce 0.8s cubic-bezier(0.34,1.56,0.64,1) calc(var(--nr-hero-base) + 0.70s) forwards, float 7s ease-in-out calc(var(--nr-hero-base) + 1.50s) infinite; }
@keyframes nr-fc-bounce {
  0%   { opacity:0; transform: translateY(30px) scale(0.92); }
  60%  { opacity:1; transform: translateY(-8px) scale(1.02); }
  80%  { transform: translateY(2px) scale(0.99); }
  100% { opacity:1; transform: translateY(0px); }
}
</style>
<script>
/* If intro already seen (returning visit), hero fires immediately */
if(sessionStorage.getItem('nr_intro_seen')){
  document.documentElement.style.setProperty('--nr-hero-base','0s');
}
</script>

