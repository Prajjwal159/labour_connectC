<script>
const toggleBtn = document.getElementById("voiceAssistantToggle");
const panel = document.getElementById("voiceAssistantPanel");
const closeBtn = document.getElementById("voiceAssistantClose");

const startBtn = document.getElementById("startVoiceBtn");
const stopBtn = document.getElementById("stopVoiceBtn");

const statusText = document.getElementById("voiceStatus");
const transcriptText = document.getElementById("voiceTranscript");
const languageSelect = document.getElementById("voiceLanguage");

const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
const synth = window.speechSynthesis;

let recognition = null;
let isListening = false;

function speakNow(text) {
    if (!("speechSynthesis" in window)) {
        statusText.textContent = "Speech output not supported";
        return;
    }

    synth.cancel();

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = languageSelect.value;
    utterance.rate = 1;
    utterance.pitch = 1;
    utterance.volume = 1;

    utterance.onstart = () => {
        console.log("Speech started");
        statusText.textContent = "Speaking";
    };

    utterance.onend = () => {
        console.log("Speech ended");
        statusText.textContent = "Finished speaking";
    };

    utterance.onerror = (e) => {
        console.log("Speech error:", e);
        statusText.textContent = "Speech error";
    };

    synth.speak(utterance);
}

toggleBtn.addEventListener("click", () => {
    panel.classList.toggle("d-none");
});

closeBtn.addEventListener("click", () => {
    panel.classList.add("d-none");
});


if (!SpeechRecognition) {
    statusText.textContent = "Voice not supported in this browser. Use Chrome or Edge.";
    startBtn.disabled = true;
    stopBtn.disabled = true;
} else {
    recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = true;
    recognition.maxAlternatives = 1;
    recognition.lang = languageSelect.value;

    languageSelect.addEventListener("change", () => {
        recognition.lang = languageSelect.value;
        statusText.textContent = "Language changed";
    });

    startBtn.addEventListener("click", () => {
        if (isListening) return;

        recognition.lang = languageSelect.value;
        transcriptText.textContent = "Listening...";
        statusText.textContent = "Listening";
        isListening = true;

        try {
            recognition.start();
        } catch (err) {
            console.log(err);
            statusText.textContent = "Could not start microphone";
            isListening = false;
        }
    });

    stopBtn.addEventListener("click", () => {
        if (recognition && isListening) {
            recognition.stop();
            statusText.textContent = "Stopped";
            isListening = false;
        }
    });

    recognition.onresult = (event) => {
        let finalTranscript = "";

        for (let i = event.resultIndex; i < event.results.length; i++) {
            if (event.results[i].isFinal) {
                finalTranscript += event.results[i][0].transcript;
            }
        }

        finalTranscript = finalTranscript.toLowerCase().trim();
        transcriptText.textContent = finalTranscript || "Listening...";

        if (!finalTranscript) return;

        if (finalTranscript.includes("job")) {
            speakNow("Opening jobs");
            setTimeout(() => {
                window.location.href = "/worker/jobs";
            }, 3000);
        }

        else if (finalTranscript.includes("loan") || finalTranscript.includes("scheme")) {
            speakNow("Opening loan schemes");
            setTimeout(() => {
                window.location.href = "/krishi-yojanas?search=loan";
            }, 3000);
        }

        else if (finalTranscript.includes("market")) {
            speakNow("Opening marketplace");
            setTimeout(() => {
                window.location.href = "/marketplace";
            }, 3000);
        }

        else if (finalTranscript.includes("farmer login")) {
            speakNow("Opening farmer login");
            setTimeout(() => {
                window.location.href = "/farmer/login";
            }, 3000);
        }

        else if (finalTranscript.includes("dashboard")) {
            speakNow("Opening dashboard");
            setTimeout(() => {
                window.location.href = "/farmer/dashboard";
            }, 3000);
        }

        else {
            speakNow("Sorry, I did not understand");
        }
    };

    recognition.onerror = (event) => {
        console.log("Speech recognition error:", event.error);
        statusText.textContent = "Error: " + event.error;
        isListening = false;
    };

    recognition.onend = () => {
        isListening = false;
        if (statusText.textContent === "Listening") {
            statusText.textContent = "Finished listening";
        }
    };
}
</script>
<script>
(() => {
    const nav = document.getElementById("landingNav");
    const revealItems = document.querySelectorAll(".landing-reveal, .job-preview-card, .impact-card, .access-role-card");

    if (nav) {
        const onScroll = () => {
            if (window.scrollY > 20) {
                nav.classList.add("is-scrolled");
            } else {
                nav.classList.remove("is-scrolled");
            }
        };
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
    }

    if ("IntersectionObserver" in window && revealItems.length > 0) {
        const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    io.unobserve(entry.target);
                }
            });
        }, { threshold: 0.18 });

        revealItems.forEach((item, index) => {
            item.style.transitionDelay = `${Math.min(index * 60, 300)}ms`;
            io.observe(item);
        });
    } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
    }
})();
</script>
<!-- Micro-interaction: scroll reveal + stagger for section cards -->
<script>
(function(){
  // Scroll-reveal
  var io = window.IntersectionObserver && new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('nr-revealed'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -48px 0px' });
  document.querySelectorAll('.soft-card,.dash-metric-card,.stat-card,.dash-action-card,.yojana-card,.job-card-v2,.labor-card,.feature-item').forEach(function(el,i){
    el.style.transitionDelay = (i % 4) * 60 + 'ms';
    el.classList.add('nr-reveal-target');
    if(io) io.observe(el); else el.classList.add('nr-revealed');
  });
  // Button ripple effect
  document.querySelectorAll('.btn,.nr-nav-btn,.auth-main-btn,.pretty-btn-green,.btn-add-product').forEach(function(btn){
    btn.addEventListener('click', function(e){
      var r = document.createElement('span');
      var rect = btn.getBoundingClientRect();
      var size = Math.max(rect.width, rect.height);
      r.className = 'nr-ripple';
      r.style.cssText = 'width:'+size+'px;height:'+size+'px;left:'+(e.clientX-rect.left-size/2)+'px;top:'+(e.clientY-rect.top-size/2)+'px';
      btn.style.position = btn.style.position || 'relative';
      btn.style.overflow = 'hidden';
      btn.appendChild(r);
      setTimeout(function(){ r.remove(); }, 600);
    });
  });
})();
</script>
</body>
</html>











