<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Namma Raitha Jobs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="landing-body">

    <!-- HERO SECTION -->
    <section class="hero-wrapper">
        <div class="hero-overlay"></div>

        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg landing-nav">
            <div class="container">
                <a class="navbar-brand brand-logo" href="/">🌾 Namma Raitha Jobs</a>

                <div class="nav-pill d-none d-lg-flex">
                    <a href="/" class="active">Home</a>
                    <a href="#about">About Us</a>
                    <a href="#solutions">Solutions</a>
                    <a href="#impact">Impact</a>
                    <a href="#access">Access</a>
                </div>

                <div>
                    <a href="/farmer/login" class="btn nav-contact-btn">Login</a>
                </div>
            </div>
        </nav>

        <!-- HERO CONTENT -->
        <div class="container hero-content">
            <div class="row align-items-center min-vh-100">
                <div class="col-lg-7">
                    <div class="hero-text-box">
                        <p class="hero-mini-tag">Digital Agriculture Workforce Platform</p>
                        <h1 class="hero-title">
                            Smart Farming Jobs for
                            <span>Future Generations</span>
                        </h1>
                        <p class="hero-subtitle">
                            Namma Raitha Jobs connects farmers and rural workers through a structured digital platform for hourly, daily, weekly, monthly, and seasonal agricultural hiring.
                        </p>

                        <div class="hero-buttons mt-4">
                            <a href="/farmer/register" class="btn btn-hero-primary">Start as Farmer ↗</a>
                            <a href="/worker/register" class="btn btn-hero-secondary">Join as Worker</a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 d-none d-lg-block">
                    <div class="hero-side-card">
                        <div class="hero-stat-row">
                            <div>
                                <h5>140M+</h5>
                                <p>Farmers in India</p>
                            </div>
                            <div>
                                <h5>5 Types</h5>
                                <p>Flexible Hiring Modes</p>
                            </div>
                        </div>

                        <div class="hero-stat-row">
                            <div>
                                <h5>2 Roles</h5>
                                <p>Farmers & Workers</p>
                            </div>
                            <div>
                                <h5>Rural First</h5>
                                <p>Built for accessibility</p>
                            </div>
                        </div>

                        <div class="hero-side-note">
                            Supports job posting, worker applications, multilingual access, and future voice input integration.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TRUST SECTION -->
    <section class="trusted-strip">
        <div class="container">
            <div class="row align-items-center text-center gy-3">
                <div class="col-lg-3 text-lg-start">
                    <p class="trusted-text mb-0">Designed to support rural hiring, agriculture, and farm workforce management</p>
                </div>
                <div class="col-lg-9">
                    <div class="brand-strip">
                        <span>Farm Hiring</span>
                        <span>Rural Jobs</span>
                        <span>Seasonal Work</span>
                        <span>Digital Access</span>
                        <span>Agri Workforce</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section class="section-space bg-white" id="about">
        <div class="container">
            <div class="section-label">Cultivating Opportunity</div>
            <div class="row align-items-center gy-5">
                <div class="col-lg-8">
                    <h2 class="big-section-heading">
                        Our platform is built to support farmers, rural workers, and agricultural communities by delivering practical digital tools that reduce hiring delays and improve livelihood opportunities.
                    </h2>
                </div>
                <div class="col-lg-4">
                    <div class="image-bubble-card">
                        <img src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=900&q=80" alt="Farming">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SOLUTIONS SECTION -->
    <section class="section-space soft-section" id="solutions">
        <div class="container">
            <div class="row gy-4 align-items-start">
                <div class="col-lg-6">
                    <div class="section-label">About Namma Raitha Jobs</div>
                    <h2 class="solution-title">
                        Smart Farming Solutions
                        <span>That Deliver Real Results</span>
                    </h2>

                    <div class="solution-feature active-feature">
                        <div class="feature-top">
                            <span>🌱</span>
                            <strong>Structured Agricultural Hiring</strong>
                            <span>—</span>
                        </div>
                        <p>
                            Farmers can post jobs based on hourly, daily, weekly, monthly, or seasonal requirements, helping them find the right labor at the right time.
                        </p>
                    </div>

                    <div class="solution-feature">
                        <div class="feature-top">
                            <span>👨‍🌾</span>
                            <strong>Worker Opportunity Access</strong>
                            <span>+</span>
                        </div>
                    </div>

                    <div class="solution-feature">
                        <div class="feature-top">
                            <span>🌐</span>
                            <strong>Multilingual & Rural-Friendly Design</strong>
                            <span>+</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <p class="solution-side-text">
                        Our intelligent workforce platform helps reduce labor shortages during peak farming seasons, improves job visibility for workers, and builds a more transparent ecosystem for rural employment.
                    </p>

                    <div class="solution-image-card">
                        <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1200&q=80" alt="Farmer working in field">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- IMPACT SECTION -->
    <section class="section-space bg-white" id="impact">
        <div class="container">
            <div class="section-label">Platform Impact</div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="impact-card">
                        <div class="impact-icon">⏱️</div>
                        <h4>Faster Hiring</h4>
                        <p>Reduce delays in finding workers during sowing, planting, and harvesting periods.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="impact-card">
                        <div class="impact-icon">💼</div>
                        <h4>Job Stability</h4>
                        <p>Workers can discover more opportunities and track applications in one place.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="impact-card">
                        <div class="impact-icon">📱</div>
                        <h4>Digital Inclusion</h4>
                        <p>Multilingual, simple, and rural-focused design supports accessible technology adoption.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ACCESS SECTION -->
    <section class="section-space soft-section" id="access">
        <div class="container">
            <div class="row align-items-center gy-4">
                <div class="col-lg-6">
                    <h2 class="access-title">Get started with the platform</h2>
                    <p class="access-text">
                        Choose your role and start using the system. Farmers can post jobs and review applicants. Workers can browse available farm jobs and apply instantly.
                    </p>
                </div>
                <div class="col-lg-6">
                    <div class="access-card">
                        <div class="access-btn-grid">
                            <a href="/farmer/register" class="btn access-main-btn">Farmer Register</a>
                            <a href="/farmer/login" class="btn access-outline-btn">Farmer Login</a>
                            <a href="/worker/register" class="btn access-main-btn blue-btn">Worker Register</a>
                            <a href="/worker/login" class="btn access-outline-btn blue-outline">Worker Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</body>
</html>