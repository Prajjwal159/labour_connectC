<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page farmer-auth-page">

<div class="auth-bg"></div>
<div class="auth-overlay"></div>

<nav class="navbar navbar-expand-lg landing-nav auth-nav">
    <div class="container">
        <a class="navbar-brand brand-logo" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/" class="btn nav-contact-btn">Home</a>
    </div>
</nav>

<div class="container auth-container">
    <div class="row align-items-center min-vh-100">
        <div class="col-lg-6 d-none d-lg-block">
            <div class="auth-left-content">
                <span class="hero-mini-tag">Farmer Access</span>
                <h1 class="auth-hero-title">Manage farm jobs with a smarter digital workflow.</h1>
                <p class="auth-hero-text">
                    Login to post agricultural jobs, review worker applications, and manage hiring in a structured and transparent way.
                </p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="auth-card">
                <h2 class="auth-title">Farmer Login</h2>
                <p class="auth-subtitle">Login to manage your job postings and workers.</p>

                <form action="/farmer/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label auth-label">Email</label>
                        <input type="email" name="email" class="form-control auth-input" required>
                    </div>

                    <div class="mb-2">
                        <label class="form-label auth-label">Password</label>
                        <input type="password" name="password" class="form-control auth-input" required>
                    </div>

                    <div class="mb-4 text-end">
                        <a href="/farmer/forgot-password" class="auth-link-green">Forgot Password?</a>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn auth-main-btn">Login</button>
                        <a href="/farmer/register" class="btn auth-outline-btn">Create Account</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

</body>
</html>