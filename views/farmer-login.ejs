<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_login_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page farmer-auth-page">

<div class="auth-bg"></div>
<div class="auth-overlay"></div>

<nav class="navbar navbar-expand-lg landing-nav auth-nav">
    <div class="container">
        <a class="navbar-brand brand-logo" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>
        <div class="d-flex gap-2">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/?lang=<%= currentLang %>" class="btn nav-contact-btn"><%= t('home') %></a>
        </div>
    </div>
</nav>

<div class="container auth-container">
    <div class="row align-items-center min-vh-100">
        <div class="col-lg-6 d-none d-lg-block">
            <div class="auth-left-content">
                <span class="hero-mini-tag"><%= t('farmer_login_tag') %></span>
                <h1 class="auth-hero-title"><%= t('farmer_login_hero') %></h1>
                <p class="auth-hero-text">
                    <%= t('farmer_login_text') %>
                </p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="auth-card">
                <h2 class="auth-title"><%= t('farmer_login_title') %></h2>
                <p class="auth-subtitle"><%= t('farmer_login_subtitle') %></p>

                <form action="/farmer/login?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('email') %></label>
                        <input type="email" name="email" class="form-control auth-input" required>
                    </div>

                    <div class="mb-2">
                        <label class="form-label auth-label"><%= t('password') %></label>
                        <input type="password" name="password" class="form-control auth-input" required>
                    </div>

                    <div class="mb-4 text-end">
                        <a href="/farmer/forgot-password?lang=<%= currentLang %>" class="auth-link-green"><%= t('forgot_password') %></a>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn auth-main-btn"><%= t('login') %></button>
                        <a href="/farmer/register?lang=<%= currentLang %>" class="btn auth-outline-btn"><%= t('create_account') %></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

</body>
</html>