<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_login_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page farmer-auth-page auth-v2-page">

<div class="auth-split-shell">
    <section class="auth-visual-panel">
        <div class="auth-bg"></div>
        <div class="auth-overlay"></div>
        <div class="auth-visual-content">
            <div class="auth-brand-row">
                <span class="auth-brand-mark">NR</span>
                <span class="auth-brand-name">Namma Raitha</span>
            </div>
            <span class="hero-mini-tag"><%= t('farmer_login_tag') %></span>
            <h1 class="auth-hero-title"><%= t('farmer_login_hero') %></h1>
            <p class="auth-hero-text"><%= t('farmer_login_text') %></p>
            <div class="auth-trust-row">
                <div class="auth-avatar-stack" aria-hidden="true">
                    <span>F1</span><span>F2</span><span>F3</span>
                </div>
                <p>Trusted by 50,000+ Farmers</p>
            </div>
        </div>
    </section>

    <section class="auth-form-panel">
        <div class="auth-form-wrap">
            <h2 class="auth-v2-title">Welcome back</h2>
            <p class="auth-v2-subtitle">Please enter your details to access your account.</p>

            <div class="auth-role-toggle" role="tablist" aria-label="Role switch">
                <a href="/farmer/login?lang=<%= currentLang %>" class="auth-role-pill is-active" aria-current="page">Farmer</a>
                <a href="/worker/login?lang=<%= currentLang %>" class="auth-role-pill">Worker</a>
            </div>

            <form action="/farmer/login?lang=<%= currentLang %>" method="POST" class="auth-v2-form">
                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('email') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">ID</span>
                        <input type="email" name="email" class="form-control auth-input" required autocomplete="email">
                    </div>
                </div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label auth-label mb-0"><%= t('password') %></label>
                        <a href="/farmer/forgot-password?lang=<%= currentLang %>" class="auth-link-green"><%= t('forgot_password') %></a>
                    </div>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">PW</span>
                        <input type="password" name="password" class="form-control auth-input" required autocomplete="current-password">
                    </div>
                </div>

                <button type="submit" class="btn auth-main-btn auth-v2-primary"><%= t('login') %></button>

                <div class="auth-or-divider"><span>OR</span></div>

                <a href="/farmer/register?lang=<%= currentLang %>" class="btn auth-outline-btn auth-v2-secondary"><%= t('create_account') %></a>
            </form>

            <div class="auth-v2-bottom-links">
                <a href="?lang=kn">KN</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Help Center</a>
            </div>
            <p class="auth-v2-footer-note">&copy; 2024 Namma Raitha Digital Ecosystem</p>
        </div>
    </section>
</div>

</body>
</html>

