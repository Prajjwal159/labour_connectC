<!DOCTYPE html>
<html>
<head>
    <title>Notifications</title>

    <style>
        body {
            font-family: Arial;
            padding: 20px;
            background: #f5f5f5;
        }

        .notification-box {
            background: white;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 10px;
            box-shadow: 0px 2px 5px rgba(0,0,0,0.1);
        }

        .title {
            font-weight: bold;
            font-size: 18px;
        }

        .message {
            margin-top: 8px;
        }
    </style>
</head>

<body>

    <h2>🔔 Notifications</h2>

    <% if (notifications.length === 0) { %>

        <p>No notifications available.</p>

    <% } %>

    <% notifications.forEach(notification => { %>

       <a href="/notification/read/<%= notification._id %>" style="text-decoration:none; color:black;">
    <div class="notification-box">

            <div class="title">
                <%= notification.title %>
            </div>

            <div class="message">
                <%= notification.message %>
            </div>

        </div>
    </a>


    <% }) %>

</body>
</html>