<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('worker_register_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page worker-auth-page">

<div class="auth-bg"></div>
<div class="auth-overlay"></div>

<nav class="navbar navbar-expand-lg landing-nav auth-nav">
    <div class="container">
        <a class="navbar-brand brand-logo" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-primary">ಕನ್ನಡ</a>
            <a href="/?lang=<%= currentLang %>" class="btn nav-contact-btn"><%= t('home') %></a>
        </div>
    </div>
</nav>

<div class="container auth-container">
    <div class="row align-items-center min-vh-100">
        <div class="col-lg-6 d-none d-lg-block">
            <div class="auth-left-content">
                <span class="hero-mini-tag"><%= t('worker_registration_tag') %></span>
                <h1 class="auth-hero-title"><%= t('worker_register_hero') %></h1>
                <p class="auth-hero-text">
                    <%= t('worker_register_text') %>
                </p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="auth-card auth-card-large">
                <h2 class="auth-title worker-title"><%= t('worker_register_title') %></h2>
                <p class="auth-subtitle"><%= t('worker_register_subtitle') %></p>

                <form action="/worker/register?lang=<%= currentLang %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('full_name') %></label>
                        <input type="text" name="full_name" class="form-control auth-input" required autocomplete="name">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('phone') %></label>
                        <input type="text" name="phone" class="form-control auth-input" required autocomplete="tel">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('village') %></label>
                        <input type="text" name="village" class="form-control auth-input" autocomplete="address-level2">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('skill_category') %></label>
                        <select name="skill_category" class="form-select auth-input" required>
                            <option value=""><%= t('select_skill') %></option>
                            <option value="Ploughing">Ploughing</option>
                            <option value="Planting">Planting</option>
                            <option value="Harvesting">Harvesting</option>
                            <option value="Irrigation">Irrigation</option>
                            <option value="Tractor Driving">Tractor Driving</option>
                            <option value="Dairy Work">Dairy Work</option>
                            <option value="Farm Maintenance">Farm Maintenance</option>
                            <option value="Loading and Packaging">Loading and Packaging</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('experience_level') %></label>
                        <select name="experience_level" class="form-select auth-input">
                            <option value=""><%= t('select_experience') %></option>
                            <option value="Beginner"><%= t('beginner') %></option>
                            <option value="Intermediate"><%= t('intermediate') %></option>
                            <option value="Experienced"><%= t('experienced') %></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('email') %></label>
                        <input type="email" name="email" class="form-control auth-input" required autocomplete="email">
                    </div>

                    <div class="mb-4">
                        <label class="form-label auth-label"><%= t('password') %></label>
                        <input type="password" name="password" class="form-control auth-input" required autocomplete="new-password">
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn auth-main-btn worker-btn"><%= t('register') %></button>
                        <a href="/worker/login?lang=<%= currentLang %>" class="btn auth-outline-btn worker-outline"><%= t('already_have_account') %></a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

</body>
</html>