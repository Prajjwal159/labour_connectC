<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('worker_register_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page worker-auth-page auth-v2-page">

<div class="auth-split-shell">
    <section class="auth-visual-panel">
        <div class="auth-bg"></div>
        <div class="auth-overlay"></div>
        <div class="auth-visual-content">
            <div class="auth-brand-row">
                <span class="auth-brand-mark">NR</span>
                <span class="auth-brand-name">Namma Raitha</span>
            </div>
            <span class="hero-mini-tag"><%= t('worker_registration_tag') %></span>
            <h1 class="auth-hero-title"><%= t('worker_register_hero') %></h1>
            <p class="auth-hero-text"><%= t('worker_register_text') %></p>
            <div class="auth-trust-row">
                <div class="auth-avatar-stack" aria-hidden="true">
                    <span>F1</span><span>F2</span><span>F3</span>
                </div>
                <p>Trusted by 50,000+ Farmers</p>
            </div>
        </div>
    </section>

    <section class="auth-form-panel">
        <div class="auth-form-wrap auth-form-wrap-register worker-register-panel">
            <h2 class="auth-v2-title">Create your account</h2>
            <p class="auth-v2-subtitle">Build your worker profile and connect with real farm opportunities.</p>

            <div class="auth-role-toggle" role="tablist" aria-label="Role switch">
                <a href="/farmer/register?lang=<%= currentLang %>" class="auth-role-pill">Farmer</a>
                <a href="/worker/register?lang=<%= currentLang %>" class="auth-role-pill is-active" aria-current="page">Worker</a>
            </div>

            <form action="/worker/register?lang=<%= currentLang %>" method="POST" class="auth-v2-form">
                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('full_name') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">NM</span>
                        <input type="text" name="full_name" class="form-control auth-input" required autocomplete="name">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('phone') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">PH</span>
                        <input type="text" name="phone" class="form-control auth-input" required autocomplete="tel">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('village') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">VG</span>
                        <input type="text" name="village" class="form-control auth-input" autocomplete="address-level2">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('skill_category') %></label>
                    <div class="skill-checkbox-grid">
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Ploughing" id="skillPloughing">
                            <label class="form-check-label" for="skillPloughing"><%= t('ploughing') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Planting" id="skillPlanting">
                            <label class="form-check-label" for="skillPlanting"><%= t('planting') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Harvesting" id="skillHarvesting">
                            <label class="form-check-label" for="skillHarvesting"><%= t('harvesting') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Irrigation" id="skillIrrigation">
                            <label class="form-check-label" for="skillIrrigation"><%= t('irrigation') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Tractor Driving" id="skillTractor">
                            <label class="form-check-label" for="skillTractor"><%= t('tractor_driving') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Dairy Work" id="skillDairy">
                            <label class="form-check-label" for="skillDairy"><%= t('dairy_work') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Farm Maintenance" id="skillMaintenance">
                            <label class="form-check-label" for="skillMaintenance"><%= t('farm_maintenance') %></label>
                        </div>
                        <div class="form-check skill-check-card">
                            <input class="form-check-input" type="checkbox" name="skill_category" value="Loading and Packaging" id="skillLoading">
                            <label class="form-check-label" for="skillLoading"><%= t('loading_packaging') %></label>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2"><%= t('choose_one_or_more_skills') %></small>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('experience_level') %></label>
                    <select name="experience_level" class="form-select auth-input">
                        <option value=""><%= t('select_experience') %></option>
                        <option value="Beginner"><%= t('beginner') %></option>
                        <option value="Intermediate"><%= t('intermediate') %></option>
                        <option value="Experienced"><%= t('experienced') %></option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('email') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">ID</span>
                        <input type="email" name="email" class="form-control auth-input" required autocomplete="email">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('password') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">PW</span>
                        <input type="password" name="password" class="form-control auth-input" required autocomplete="new-password">
                    </div>
                </div>

                <button type="submit" class="btn auth-main-btn auth-v2-primary"><%= t('register') %></button>

                <div class="auth-or-divider"><span>OR</span></div>

                <a href="/worker/login?lang=<%= currentLang %>" class="btn auth-outline-btn auth-v2-secondary"><%= t('already_have_account') %></a>
            </form>

            <div class="auth-v2-bottom-links">
                <a href="?lang=kn">KN</a>
                <a href="#">Privacy Policy</a>
                <a href="#">Help Center</a>
            </div>
            <p class="auth-v2-footer-note">&copy; 2024 Namma Raitha Digital Ecosystem</p>
        </div>
    </section>
</div>

</body>
</html>

