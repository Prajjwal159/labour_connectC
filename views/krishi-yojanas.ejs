<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Krishi Yojanas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<%
    const jobsLink = typeof jobsPortalLink !== "undefined"
        ? jobsPortalLink
        : `/worker/jobs?lang=${currentLang}`;
    const navLinks = [
      { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
      { key: 'jobs', href: jobsLink, label: 'Jobs' },
      { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
    ];
%>
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(10,44,82,0.5), rgba(239,246,255,0.94) 50%, rgba(245,249,255,1));"></div>
<%- include('partials/unified-navbar', { fixed: false, active: 'yojanas', links: navLinks }) %>

<div class="container page-content">
    <div class="row align-items-center mb-4">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Krishi Yojanas</div>
                <h1 class="premium-section-title text-white">Farmer schemes and benefits</h1>
                <p>Explore important government schemes, benefits, eligibility, and official links.</p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4 mb-4">
    <h4 class="mb-3">Filter Schemes</h4>
    <form action="/krishi-yojanas" method="GET" class="row g-3">
        <input type="hidden" name="lang" value="<%= currentLang %>">

        <div class="col-md-4">
            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search scheme, loan, insurance, subsidy..."
                value="<%= search || '' %>"
            >
        </div>

        <div class="col-md-4">
            <select name="category" class="form-select">
                <option value="All" <%= selectedCategory === "All" ? "selected" : "" %>>All Categories</option>
                <option value="Subsidy" <%= selectedCategory === "Subsidy" ? "selected" : "" %>>Subsidy</option>
                <option value="Insurance" <%= selectedCategory === "Insurance" ? "selected" : "" %>>Insurance</option>
                <option value="Loan" <%= selectedCategory === "Loan" ? "selected" : "" %>>Loan</option>
                <option value="Irrigation" <%= selectedCategory === "Irrigation" ? "selected" : "" %>>Irrigation</option>
                <option value="Pension" <%= selectedCategory === "Pension" ? "selected" : "" %>>Pension</option>
                <option value="Market" <%= selectedCategory === "Market" ? "selected" : "" %>>Market</option>
                <option value="Infrastructure" <%= selectedCategory === "Infrastructure" ? "selected" : "" %>>Infrastructure</option>
                <option value="Organic" <%= selectedCategory === "Organic" ? "selected" : "" %>>Organic</option>
                <option value="Livestock" <%= selectedCategory === "Livestock" ? "selected" : "" %>>Livestock</option>
                <option value="Energy" <%= selectedCategory === "Energy" ? "selected" : "" %>>Energy</option>
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn pretty-btn-green w-100">Search</button>
        </div>

        <div class="col-md-2">
            <a href="/krishi-yojanas?lang=<%= currentLang %>" class="btn pretty-btn-outline w-100">Clear</a>
        </div>
    </form>
</div>

    <div class="soft-card p-4 mb-4">
        <h4 class="mb-3">About this page</h4>
        <p class="mb-0">
            This page highlights important farmer-focused schemes from official government scheme pages.
        </p>
    </div>

    <div class="soft-card p-4">
        <% if (!yojanas || yojanas.length === 0) { %>
            <div class="alert alert-warning mb-0">
                No schemes available in this category.
            </div>
        <% } else { %>
            <div class="row">
                <% yojanas.forEach(item => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-4 full-height-card">
                            <h4 class="mb-3"><%= item.title %></h4>

                            <div class="mb-3">
                                <span class="action-pill"><%= item.category %></span>
                            </div>

                            <p class="job-detail-line">
                                <strong>Description:</strong>
                                <%= item.description %>
                            </p>

                            <p class="job-detail-line">
                                <strong>Benefits:</strong>
                                <%= item.benefits %>
                            </p>

                            <p class="job-detail-line">
                                <strong>Eligibility:</strong>
                                <%= item.eligibility %>
                            </p>

                            <div class="mt-3">
                                <a href="<%= item.link %>" target="_blank" class="btn pretty-btn-green">
                                    View Official Scheme
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
<footer class="platform-footer">
  <div class="row g-4">
    <div class="col-lg-5">
      <a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
      <p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Platform</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/marketplace?lang=<%= currentLang %>">Marketplace</a>
        <a href="<%= jobsLink %>">Jobs</a>
        <a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Support</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/?lang=<%= currentLang %>">Home</a>
        <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
      </div>
    </div>
    <div class="col-12 col-lg-3">
      <div class="footer-col-title">Legal</div>
      <div class="d-grid gap-2 mt-2">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">(c) 2024 Namma Raitha Digital Ecosystem.</div>
</footer>

<%- include('partials/micro-interactions') %>
</body>
</html>

