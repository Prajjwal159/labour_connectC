<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_forgot_password_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page farmer-auth-page auth-v2-page">

<div class="auth-split-shell">
    <section class="auth-visual-panel">
        <div class="auth-bg"></div>
        <div class="auth-overlay"></div>
        <div class="auth-visual-content">
            <div class="auth-brand-row">
                <span class="auth-brand-mark">NR</span>
                <span class="auth-brand-name">Namma Raitha</span>
            </div>
            <span class="hero-mini-tag">Farmer Account Recovery</span>
            <h1 class="auth-hero-title">Reset your password securely</h1>
            <p class="auth-hero-text">Enter your registered details and we'll update your password instantly.</p>
        </div>
    </section>

    <section class="auth-form-panel">
        <div class="auth-form-wrap">
            <h2 class="auth-v2-title">Forgot Password</h2>
            <p class="auth-v2-subtitle">Enter your registered email, phone and new password.</p>

            <form action="/farmer/forgot-password?lang=<%= currentLang %>" method="POST" class="auth-v2-form">
                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('registered_email') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">@</span>
                        <input type="email" name="email" class="form-control auth-input" required autocomplete="email">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label auth-label"><%= t('registered_phone') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">#</span>
                        <input type="text" name="phone" class="form-control auth-input" required>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label auth-label"><%= t('new_password') %></label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">PW</span>
                        <input type="password" name="newPassword" class="form-control auth-input" required>
                    </div>
                </div>
                <button type="submit" class="btn auth-main-btn auth-v2-primary"><%= t('update_password') %></button>
                <a href="/farmer/login?lang=<%= currentLang %>" class="btn auth-outline-btn auth-v2-secondary mt-2"><%= t('back') %></a>
            </form>

            <div class="auth-v2-bottom-links">
                <a href="?lang=kn">KN</a>
                <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
            </div>
            <p class="auth-v2-footer-note">&copy; 2024 Namma Raitha Digital Ecosystem</p>
        </div>
    </section>
</div>

</body>
</html>
