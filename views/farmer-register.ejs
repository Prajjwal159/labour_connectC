<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('farmer_register_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page farmer-auth-page">

<div class="auth-bg"></div>
<div class="auth-overlay"></div>

<nav class="navbar navbar-expand-lg landing-nav auth-nav">
    <div class="container">
        <a class="navbar-brand brand-logo" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/?lang=<%= currentLang %>" class="btn nav-contact-btn"><%= t('home') %></a>
        </div>
    </div>
</nav>

<div class="container auth-container">
    <div class="row align-items-center min-vh-100">
        <div class="col-lg-6 d-none d-lg-block">
            <div class="auth-left-content">
                <span class="hero-mini-tag"><%= t('farmer_registration_tag') %></span>
                <h1 class="auth-hero-title"><%= t('farmer_register_hero') %></h1>
                <p class="auth-hero-text">
                    <%= t('farmer_register_text') %>
                </p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="auth-card auth-card-large">
                <h2 class="auth-title"><%= t('farmer_register_title') %></h2>
                <p class="auth-subtitle"><%= t('farmer_register_subtitle') %></p>

                <form action="/farmer/register?lang=<%= currentLang %>" method="POST">
                    
                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('full_name') %></label>
                        <input type="text" name="full_name" class="form-control auth-input" required autocomplete="name">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('phone') %></label>
                        <input type="text" name="phone" class="form-control auth-input" required autocomplete="tel">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('village') %></label>
                        <input type="text" name="village" class="form-control auth-input" autocomplete="address-level2">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label"><%= t('email') %></label>
                        <input type="email" name="email" class="form-control auth-input" required autocomplete="email">
                    </div>

                    <div class="mb-3">
                        <label class="form-label auth-label">Choose Subscription Plan</label>
                        <select name="subscription_plan" class="form-select auth-input" required>
                            <option value="">Select Plan</option>
                            <option value="59|3">₹59 - 3 Months</option>
                            <option value="69|5">₹69 - 5 Months</option>
                            <option value="79|6">₹79 - 6 Months</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label auth-label"><%= t('password') %></label>
                        <input type="password" name="password" class="form-control auth-input" required autocomplete="new-password">
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn auth-main-btn"><%= t('register') %></button>
                        <a href="/farmer/login?lang=<%= currentLang %>" class="btn auth-outline-btn"><%= t('already_have_account') %></a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

</body>
</html>