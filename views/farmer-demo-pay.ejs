<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demo Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4">
                <div class="card-body p-4 text-center">
                    <h2 class="mb-3 text-success">Demo Payment</h2>
                    <p class="mb-4">This is a fake payment page for project demo only.</p>

                    <form action="/farmer/demo-pay/<%= token %>?lang=<%= currentLang %>" method="POST">
                        <button type="submit" class="btn btn-success btn-lg">
                            Complete Demo Payment
                        </button>
                    </form>

                    <p class="text-muted mt-4 mb-0">
                        After payment success, return to your desktop browser.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>