<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demo Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:90vh;">
        <div class="col-lg-5">
            <div class="frost-card p-5 text-center">
                <h2 class="text-success fw-bold mb-3">Demo Payment</h2>
                <p class="mb-4">This is a fake payment page for project demo.</p>

                <form action="/farmer/demo-pay/<%= token %>?lang=<%= currentLang %>" method="POST">
                    <button type="submit" class="btn pretty-btn-green">
                        Complete Demo Payment
                    </button>
                </form>

                <p class="text-muted mt-4 mb-0">
                    After payment, return to the laptop page.
                </p>
            </div>
        </div>
    </div>
</div>
</body>
</html>