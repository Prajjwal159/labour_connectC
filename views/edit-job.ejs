<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('edit_job') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(90deg, rgba(20,74,36,0.58), rgba(44,128,72,0.18), rgba(255,255,255,0.05));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>
        <div class="d-flex gap-2">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center" style="min-height:82vh;">
        <div class="col-lg-5">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('update_job_details') %></div>
                <h1 class="premium-section-title text-white"><%= t('edit_job_hero') %></h1>
                <p><%= t('edit_job_text') %></p>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="frost-card p-4 pretty-form">
                <h3 class="mb-2 text-success fw-bold"><%= t('edit_job') %></h3>
                <p class="premium-subtitle mb-4"><%= t('edit_job_subtitle') %></p>

                <form action="/farmer/edit-job/<%= job.id %>?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label><%= t('job_title') %></label>
                        <input type="text" name="job_title" class="form-control" value="<%= job.job_title %>" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('category') %></label>
                        <select name="category" class="form-select" required>
                            <option value="Ploughing" <%= job.category === 'Ploughing' ? 'selected' : '' %>><%= t('ploughing') %></option>
                            <option value="Planting" <%= job.category === 'Planting' ? 'selected' : '' %>><%= t('planting') %></option>
                            <option value="Harvesting" <%= job.category === 'Harvesting' ? 'selected' : '' %>><%= t('harvesting') %></option>
                            <option value="Irrigation" <%= job.category === 'Irrigation' ? 'selected' : '' %>><%= t('irrigation') %></option>
                            <option value="Tractor Driving" <%= job.category === 'Tractor Driving' ? 'selected' : '' %>><%= t('tractor_driving') %></option>
                            <option value="Dairy Work" <%= job.category === 'Dairy Work' ? 'selected' : '' %>><%= t('dairy_work') %></option>
                            <option value="Farm Maintenance" <%= job.category === 'Farm Maintenance' ? 'selected' : '' %>><%= t('farm_maintenance') %></option>
                            <option value="Loading and Packaging" <%= job.category === 'Loading and Packaging' ? 'selected' : '' %>><%= t('loading_packaging') %></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label><%= t('work_type') %></label>
                        <select name="work_type" class="form-select" required>
                            <option value="Hourly" <%= job.work_type === 'Hourly' ? 'selected' : '' %>><%= t('hourly') %></option>
                            <option value="Daily" <%= job.work_type === 'Daily' ? 'selected' : '' %>><%= t('daily') %></option>
                            <option value="Weekly" <%= job.work_type === 'Weekly' ? 'selected' : '' %>><%= t('weekly') %></option>
                            <option value="Monthly" <%= job.work_type === 'Monthly' ? 'selected' : '' %>><%= t('monthly') %></option>
                            <option value="Seasonal" <%= job.work_type === 'Seasonal' ? 'selected' : '' %>><%= t('seasonal') %></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label><%= t('description') %></label>
                        <textarea name="description" class="form-control"><%= job.description || '' %></textarea>
                    </div>

                    <div class="mb-3">
                        <label><%= t('location') %></label>
                        <input type="text" name="location" class="form-control" value="<%= job.location %>" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('wage') %> (₹)</label>
                        <input type="number" name="wage" class="form-control" value="<%= job.wage %>" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('payment_mode') %></label>
                        <select name="payment_mode" class="form-select" required>
                            <option value="Cash" <%= job.payment_mode === 'Cash' ? 'selected' : '' %>><%= t('cash') %></option>
                            <option value="UPI" <%= job.payment_mode === 'UPI' ? 'selected' : '' %>>UPI</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label><%= t('start_date') %></label>
                            <input type="date" name="start_date" class="form-control" value="<%= job.start_date ? job.start_date.toISOString().split('T')[0] : '' %>">
                        </div>

                        <div class="col-md-6 mb-4">
                            <label><%= t('end_date') %></label>
                            <input type="date" name="end_date" class="form-control" value="<%= job.end_date ? job.end_date.toISOString().split('T')[0] : '' %>">
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green"><%= t('update_job') %></button>
                        <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn pretty-btn-outline"><%= t('cancel') %></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>