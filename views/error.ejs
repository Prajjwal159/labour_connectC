<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(98,16,16,0.55), rgba(250,241,241,0.92) 55%, rgba(250,245,245,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/" class="btn glass-btn">Home</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:75vh;">
        <div class="col-lg-7">
            <div class="frost-card p-5 text-center">
                <div class="message-icon">❌</div>
                <h1 class="premium-section-title text-danger">Something Went Wrong</h1>
                <p class="premium-subtitle fs-5 mb-4"><%= message %></p>

                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="<%= backLink %>" class="btn pretty-btn-red">Try Again</a>
                    <a href="/" class="btn pretty-btn-outline">Go Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>