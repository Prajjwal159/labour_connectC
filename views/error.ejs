<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('error_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(98,16,16,0.45), rgba(239,236,255,0.95) 52%, rgba(250,245,255,1));"></div>

<%
    const navLinks = [
      { key: 'home',        href: `/?lang=${currentLang}`,               label: 'Home' },
      { key: 'marketplace', href: `/marketplace?lang=${currentLang}`,    label: 'Marketplace' },
      { key: 'jobs',        href: (typeof jobsPortalLink !== 'undefined' ? jobsPortalLink : `/worker/jobs?lang=${currentLang}`), label: 'Jobs' },
      { key: 'yojanas',    href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
    ];
%>
<%- include('partials/unified-navbar', { fixed: false, active: '', links: navLinks }) %>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:75vh;">
        <div class="col-lg-6 text-center">
            <div class="frost-card p-5" style="border-radius:24px;">
                <div style="font-size:3.5rem; margin-bottom:16px;">⚠️</div>
                <h1 class="auth-v2-title mb-2" style="color:#8b1a1a;"><%= t('something_went_wrong') %></h1>
                <p class="auth-v2-subtitle mb-4"><%= message %></p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="<%= backLink %><%= backLink.includes('?') ? '&' : '?' %>lang=<%= currentLang %>" class="btn auth-main-btn auth-v2-primary"><%= t('try_again') %></a>
                    <a href="/?lang=<%= currentLang %>" class="btn auth-outline-btn auth-v2-secondary"><%= t('go_home') %></a>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>
