<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('job_applications_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell jobs-ui-page">
<%
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: `/farmer/jobs?lang=${currentLang}`, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
  const navActions = [
    { href: `?lang=${currentLang === 'en' ? 'kn' : 'en'}`, label: currentLang === 'en' ? 'EN' : 'KN', className: 'nr-nav-btn nr-nav-btn-ghost' },
    { href: `/farmer/dashboard?lang=${currentLang}`, label: 'Dashboard', className: 'nr-nav-btn nr-nav-btn-primary' }
  ];
%>
<%- include('partials/unified-navbar', { navId: 'landingNav', fixed: false, active: 'jobs', links: navLinks, actions: navActions }) %>

<main class="container jobs-page-wrap">
    <section class="jobs-hero-card">
        <h1><%= t('applications_for') %>: <%= job.job_title %></h1>
        <p><%= t('job_applications_text') %></p>
        <div class="jobs-skill-pill"><%= t('current_job_version') %>: <strong><%= t('version') %> <%= job.version || 1 %></strong></div>
    </section>
    <section class="jobs-results-wrap">
        <% const versions = Object.keys(groupedApplications).sort((a, b) => Number(b) - Number(a)); %>
        <% if (versions.length === 0) { %>
            <div class="jobs-empty"><%= t('no_workers_applied') %></div>
        <% } else { %>
            <% versions.forEach(version => { %>
                <div class="jobs-version-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0"><%= t('version') %> <%= version %> <%= t('applications') %></h4>
                        <% if (Number(version) === (job.version || 1)) { %>
                            <span class="badge bg-success status-badge"><%= t('current_version') %></span>
                        <% } else { %>
                            <span class="badge bg-secondary status-badge"><%= t('older_version') %></span>
                        <% } %>
                    </div>
                    <div class="jobs-cards-grid">
                        <% groupedApplications[version].forEach(app => { %>
                            <article class="jobs-listing-card">
                                <h5><%= app.full_name %></h5>
                                <p class="job-detail-line"><strong><%= t('email') %>:</strong> <%= app.email %></p>
                                <p class="job-detail-line"><strong><%= t('phone') %>:</strong> <%= app.phone %></p>
                                <p class="job-detail-line"><strong><%= t('village') %>:</strong> <%= app.village %></p>
                                <p class="job-detail-line"><strong><%= t('skill') %>:</strong> <%= app.skill_category %></p>
                                <p class="job-detail-line"><strong><%= t('experience_level') %>:</strong> <%= app.experience_level %></p>
                                <p class="job-detail-line"><strong><%= t('applied_for_version') %>:</strong> <span class="badge bg-info text-dark status-badge"><%= t('version') %> <%= app.job_version %></span></p>
                                <p class="job-detail-line">
                                    <strong><%= t('status') %>:</strong>
                                    <% if (app.application_status === 'Applied') { %><span class="badge bg-warning text-dark status-badge"><%= t('applied') %></span>
                                    <% } else if (app.application_status === 'Accepted') { %><span class="badge bg-success status-badge"><%= t('accepted') %></span>
                                    <% } else { %><span class="badge bg-danger status-badge"><%= t('rejected') %></span><% } %>
                                </p>
                                <% if (Number(version) < (job.version || 1)) { %>
                                    <div class="alert alert-secondary mt-2"><%= t('older_job_version_text') %></div>
                                <% } else { %>
                                    <div class="alert alert-success mt-2"><%= t('latest_job_version_text') %></div>
                                <% } %>
                                <% if (app.application_status === 'Applied' && Number(version) === (job.version || 1)) { %>
                                    <div class="d-flex gap-2 mt-3">
                                        <form action="/farmer/application/update/<%= app.id %>?lang=<%= currentLang %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Accepted">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-green"><%= t('accept') %></button>
                                        </form>
                                        <form action="/farmer/application/update/<%= app.id %>?lang=<%= currentLang %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Rejected">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-red"><%= t('reject') %></button>
                                        </form>
                                    </div>
                                <% } %>
                            </article>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </section>
</main>

<footer class="platform-footer"><div class="row g-4"><div class="col-lg-5"><a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a><p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p></div><div class="col-6 col-lg-2"><div class="footer-col-title">Platform</div><div class="d-grid gap-2 mt-2"><a href="/marketplace?lang=<%= currentLang %>">Marketplace</a><a href="/farmer/dashboard?lang=<%= currentLang %>">Jobs</a><a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a></div></div><div class="col-6 col-lg-2"><div class="footer-col-title">Support</div><div class="d-grid gap-2 mt-2"><a href="/?lang=<%= currentLang %>">Home</a><a href="/farmer/login?lang=<%= currentLang %>">Login</a></div></div><div class="col-12 col-lg-3"><div class="footer-col-title">Legal</div><div class="d-grid gap-2 mt-2"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a></div></div></div><div class="footer-bottom">© 2024 Namma Raitha Digital Ecosystem.</div></footer>
</body>
</html>

