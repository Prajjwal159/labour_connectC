<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('job_applications_title') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1492496913980-501348b61469?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(31,83,41,0.46), rgba(248,251,246,0.95) 46%, rgba(250,252,249,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('application_history') %></div>
                <h1 class="premium-section-title text-white"><%= t('applications_for') %>: <%= job.job_title %></h1>
                <p><%= t('job_applications_text') %></p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4 mb-4">
        <h4 class="mb-2"><%= t('job_overview') %></h4>
        <p class="job-detail-line">
            <strong><%= t('current_job_version') %>:</strong>
            <span class="badge bg-dark status-badge"><%= t('version') %> <%= job.version || 1 %></span>
        </p>
        <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= job.category %></p>
        <p class="job-detail-line"><strong><%= t('work_type') %>:</strong> <%= job.work_type %></p>
        <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= job.location %></p>
    </div>

    <% const versions = Object.keys(groupedApplications).sort((a, b) => Number(b) - Number(a)); %>

    <% if (versions.length === 0) { %>
        <div class="soft-card p-4">
            <div class="alert alert-warning mb-0"><%= t('no_workers_applied') %></div>
        </div>
    <% } else { %>

        <% versions.forEach(version => { %>
            <div class="soft-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <h4 class="mb-0"><%= t('version') %> <%= version %> <%= t('applications') %></h4>

                    <% if (Number(version) === (job.version || 1)) { %>
                        <span class="badge bg-success status-badge"><%= t('current_version') %></span>
                    <% } else { %>
                        <span class="badge bg-secondary status-badge"><%= t('older_version') %></span>
                    <% } %>
                </div>

                <div class="row">
                    <% groupedApplications[version].forEach(app => { %>
                        <div class="col-md-6 mb-4">
                            <div class="soft-card p-4 full-height-card">
                                <h5 class="mb-3"><%= app.full_name %></h5>

                                <p class="job-detail-line"><strong><%= t('email') %>:</strong> <%= app.email %></p>
                                <p class="job-detail-line"><strong><%= t('phone') %>:</strong> <%= app.phone %></p>
                                <p class="job-detail-line"><strong><%= t('village') %>:</strong> <%= app.village %></p>
                                <p class="job-detail-line"><strong><%= t('skill') %>:</strong> <%= app.skill_category %></p>
                                <p class="job-detail-line"><strong><%= t('experience_level') %>:</strong> <%= app.experience_level %></p>

                                <p class="job-detail-line">
                                    <strong><%= t('applied_for_version') %>:</strong>
                                    <span class="badge bg-info text-dark status-badge"><%= t('version') %> <%= app.job_version %></span>
                                </p>

                                <p class="job-detail-line">
                                    <strong><%= t('status') %>:</strong>
                                    <% if (app.application_status === 'Applied') { %>
                                        <span class="badge bg-warning text-dark status-badge"><%= t('applied') %></span>
                                    <% } else if (app.application_status === 'Accepted') { %>
                                        <span class="badge bg-success status-badge"><%= t('accepted') %></span>
                                    <% } else { %>
                                        <span class="badge bg-danger status-badge"><%= t('rejected') %></span>
                                    <% } %>
                                </p>

                                <% if (Number(version) < (job.version || 1)) { %>
                                    <div class="alert alert-secondary mt-3">
                                        <%= t('older_job_version_text') %>
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-success mt-3">
                                        <%= t('latest_job_version_text') %>
                                    </div>
                                <% } %>

                                <% if (app.application_status === 'Applied' && Number(version) === (job.version || 1)) { %>
                                    <div class="mt-3 d-flex gap-2 flex-wrap">
                                        <form action="/farmer/application/update/<%= app.id %>?lang=<%= currentLang %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Accepted">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-green"><%= t('accept') %></button>
                                        </form>

                                        <form action="/farmer/application/update/<%= app.id %>?lang=<%= currentLang %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Rejected">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-red"><%= t('reject') %></button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>

    <% } %>
</div>
</body>
</html>