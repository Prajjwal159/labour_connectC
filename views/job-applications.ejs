<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Applications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1492496913980-501348b61469?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(31,83,41,0.46), rgba(248,251,246,0.95) 46%, rgba(250,252,249,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/farmer/dashboard" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Application History</div>
                <h1 class="premium-section-title text-white">Applications for: <%= job.job_title %></h1>
                <p>Review applicants grouped by job version and manage the latest version clearly.</p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4 mb-4">
        <h4 class="mb-2">Job Overview</h4>
        <p class="job-detail-line"><strong>Current Job Version:</strong> <span class="badge bg-dark status-badge">Version <%= job.version || 1 %></span></p>
        <p class="job-detail-line"><strong>Category:</strong> <%= job.category %></p>
        <p class="job-detail-line"><strong>Work Type:</strong> <%= job.work_type %></p>
        <p class="job-detail-line"><strong>Location:</strong> <%= job.location %></p>
    </div>

    <% const versions = Object.keys(groupedApplications).sort((a, b) => Number(b) - Number(a)); %>

    <% if (versions.length === 0) { %>
        <div class="soft-card p-4">
            <div class="alert alert-warning mb-0">No workers have applied yet.</div>
        </div>
    <% } else { %>

        <% versions.forEach(version => { %>
            <div class="soft-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <h4 class="mb-0">Version <%= version %> Applications</h4>

                    <% if (Number(version) === (job.version || 1)) { %>
                        <span class="badge bg-success status-badge">Current Version</span>
                    <% } else { %>
                        <span class="badge bg-secondary status-badge">Older Version</span>
                    <% } %>
                </div>

                <div class="row">
                    <% groupedApplications[version].forEach(app => { %>
                        <div class="col-md-6 mb-4">
                            <div class="soft-card p-4 full-height-card">
                                <h5 class="mb-3"><%= app.full_name %></h5>

                                <p class="job-detail-line"><strong>Email:</strong> <%= app.email %></p>
                                <p class="job-detail-line"><strong>Phone:</strong> <%= app.phone %></p>
                                <p class="job-detail-line"><strong>Village:</strong> <%= app.village %></p>
                                <p class="job-detail-line"><strong>Skill:</strong> <%= app.skill_category %></p>
                                <p class="job-detail-line"><strong>Experience:</strong> <%= app.experience_level %></p>

                                <p class="job-detail-line">
                                    <strong>Applied For Version:</strong>
                                    <span class="badge bg-info text-dark status-badge">Version <%= app.job_version %></span>
                                </p>

                                <p class="job-detail-line">
                                    <strong>Status:</strong>
                                    <% if (app.application_status === 'Applied') { %>
                                        <span class="badge bg-warning text-dark status-badge">Applied</span>
                                    <% } else if (app.application_status === 'Accepted') { %>
                                        <span class="badge bg-success status-badge">Accepted</span>
                                    <% } else { %>
                                        <span class="badge bg-danger status-badge">Rejected</span>
                                    <% } %>
                                </p>

                                <% if (Number(version) < (job.version || 1)) { %>
                                    <div class="alert alert-secondary mt-3">
                                        This application belongs to an older version of the job.
                                    </div>
                                <% } else { %>
                                    <div class="alert alert-success mt-3">
                                        This application belongs to the latest version of the job.
                                    </div>
                                <% } %>

                                <% if (app.application_status === 'Applied' && Number(version) === (job.version || 1)) { %>
                                    <div class="mt-3 d-flex gap-2 flex-wrap">
                                        <form action="/farmer/application/update/<%= app.id %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Accepted">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-green">Accept</button>
                                        </form>

                                        <form action="/farmer/application/update/<%= app.id %>" method="POST" class="d-inline">
                                            <input type="hidden" name="status" value="Rejected">
                                            <input type="hidden" name="jobId" value="<%= job.id %>">
                                            <button type="submit" class="btn pretty-btn-red">Reject</button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>

    <% } %>
</div>
</body>
</html>