<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Renew Subscription</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 Namma Raitha Jobs</a>
        <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:85vh;">
        <div class="col-lg-6">
            <div class="frost-card p-5">
                <h2 class="text-success fw-bold mb-3">Renew Subscription</h2>
                <p class="premium-subtitle mb-4">Choose a plan to continue using farmer features.</p>

                <form action="/farmer/renew-subscription?lang=<%= currentLang %>" method="POST">
                    <div class="mb-4">
                        <label class="form-label">Choose Subscription Plan</label>
                        <select name="subscription_plan" class="form-select" required>
                            <option value="">Select Plan</option>
                            <option value="59|3">₹59 - 3 Months</option>
                            <option value="69|5">₹69 - 5 Months</option>
                            <option value="79|6">₹79 - 6 Months</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green">Proceed to Payment</button>
                        <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn pretty-btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>