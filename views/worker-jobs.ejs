<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('available_jobs') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(18,70,42,0.44), rgba(244,251,245,0.96) 48%, rgba(248,252,248,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/worker/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('available_agricultural_jobs') %></div>
                <h1 class="premium-section-title text-white"><%= t('find_farm_work_title') %></h1>
                <p><%= t('find_farm_work_text') %></p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4 mb-4">
        <h4 class="mb-3"><%= t('filter_jobs') %></h4>
        <p class="premium-subtitle mb-4">
            <%= t('your_skill_category') %>: 
            <strong><%= workerSkills && workerSkills.length ? workerSkills.join(", ") : 'N/A' %></strong>
        </p>
        <form action="/worker/jobs" method="GET">
            <input type="hidden" name="lang" value="<%= currentLang %>">

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label"><%= t('location') %></label>
                    <input type="text" name="location" class="form-control" value="<%= filters?.location || '' %>" placeholder="<%= t('enter_location') %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label"><%= t('job_title_keyword') %></label>
                    <input type="text" name="keyword" class="form-control" value="<%= filters?.keyword || '' %>" placeholder="<%= t('search_job_title') %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label"><%= t('category') %></label>
                    <select name="category" class="form-select">
                        <option value=""><%= t('all_categories') %></option>
                        <option value="Ploughing" <%= filters?.category === 'Ploughing' ? 'selected' : '' %>><%= t('ploughing') %></option>
                        <option value="Planting" <%= filters?.category === 'Planting' ? 'selected' : '' %>><%= t('planting') %></option>
                        <option value="Harvesting" <%= filters?.category === 'Harvesting' ? 'selected' : '' %>><%= t('harvesting') %></option>
                        <option value="Irrigation" <%= filters?.category === 'Irrigation' ? 'selected' : '' %>><%= t('irrigation') %></option>
                        <option value="Tractor Driving" <%= filters?.category === 'Tractor Driving' ? 'selected' : '' %>><%= t('tractor_driving') %></option>
                        <option value="Dairy Work" <%= filters?.category === 'Dairy Work' ? 'selected' : '' %>><%= t('dairy_work') %></option>
                        <option value="Farm Maintenance" <%= filters?.category === 'Farm Maintenance' ? 'selected' : '' %>><%= t('farm_maintenance') %></option>
                        <option value="Loading and Packaging" <%= filters?.category === 'Loading and Packaging' ? 'selected' : '' %>><%= t('loading_packaging') %></option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label"><%= t('work_type') %></label>
                    <select name="work_type" class="form-select">
                        <option value=""><%= t('all_work_types') %></option>
                        <option value="Hourly" <%= filters?.work_type === 'Hourly' ? 'selected' : '' %>><%= t('hourly') %></option>
                        <option value="Daily" <%= filters?.work_type === 'Daily' ? 'selected' : '' %>><%= t('daily') %></option>
                        <option value="Weekly" <%= filters?.work_type === 'Weekly' ? 'selected' : '' %>><%= t('weekly') %></option>
                        <option value="Monthly" <%= filters?.work_type === 'Monthly' ? 'selected' : '' %>><%= t('monthly') %></option>
                        <option value="Seasonal" <%= filters?.work_type === 'Seasonal' ? 'selected' : '' %>><%= t('seasonal') %></option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label"><%= t('minimum_wage') %></label>
                    <input type="number" name="min_wage" class="form-control" value="<%= filters?.min_wage || '' %>" placeholder="<%= t('enter_minimum_wage') %>">
                </div>

                <div class="col-md-4">
                    <label class="form-label"><%= t('payment_mode') %></label>
                    <select name="payment_mode" class="form-select">
                        <option value=""><%= t('all_payment_modes') %></option>
                        <option value="Cash" <%= filters?.payment_mode === 'Cash' ? 'selected' : '' %>><%= t('cash') %></option>
                        <option value="UPI" <%= filters?.payment_mode === 'UPI' ? 'selected' : '' %>>UPI</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label"><%= t('sort_by') %></label>
                    <select name="sort" class="form-select">
                        <option value=""><%= t('default_sort') %></option>
                        <option value="highest_wage" <%= filters?.sort === 'highest_wage' ? 'selected' : '' %>><%= t('highest_wage') %></option>
                        <option value="newest" <%= filters?.sort === 'newest' ? 'selected' : '' %>><%= t('newest_jobs') %></option>
                        <option value="skill_match" <%= filters?.sort === 'skill_match' ? 'selected' : '' %>><%= t('skill_matched_first') %></option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button type="submit" class="btn pretty-btn-green w-100"><%= t('apply_filters') %></button>
                    <a href="/worker/jobs?lang=<%= currentLang %>" class="btn pretty-btn-outline w-100"><%= t('clear_filters') %></a>
                </div>
            </div>
        </form>
    </div>

    <div class="soft-card p-4">
        <% if (jobs.length === 0) { %>
            <div class="alert alert-warning mb-0"><%= t('no_jobs_available') %></div>
        <% } else { %>
            <div class="row">
                <% jobs.forEach(job => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-4 full-height-card">
                            <h5 class="mb-3"><%= job.job_title %></h5>

                            <div class="mb-3">
                                <span class="action-pill"><%= job.category %></span>
                                <span class="action-pill blue"><%= job.work_type %></span>
                                <span class="action-pill gold"><%= job.payment_mode %></span>
                            </div>

                            <p class="premium-subtitle"><%= job.description || t('no_description_provided') %></p>

                            <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= job.location %></p>
                            <p class="job-detail-line"><strong><%= t('wage') %>:</strong> ₹<%= job.wage %></p>
                            <p class="job-detail-line"><strong><%= t('start_date') %>:</strong> <%= job.start_date ? job.start_date.toISOString().split('T')[0] : 'N/A' %></p>
                            <p class="job-detail-line"><strong><%= t('end_date') %>:</strong> <%= job.end_date ? job.end_date.toISOString().split('T')[0] : 'N/A' %></p>
                            <p class="job-detail-line"><strong><%= t('workers_required') %>:</strong> <%= job.workers_required %></p>
                            <p class="job-detail-line"><strong>Workers Filled:</strong> <%= job.applied_count || 0 %> / <%= job.workers_required %></p>

                            <form action="/worker/apply/<%= job.id %>?lang=<%= currentLang %>" method="POST" class="mt-3">
                                <button type="submit" class="btn pretty-btn-green w-100"><%= t('apply_now') %></button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>