<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Available Jobs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(18,70,42,0.44), rgba(244,251,245,0.96) 48%, rgba(248,252,248,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/worker/dashboard" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Available Agricultural Jobs</div>
                <h1 class="premium-section-title text-white">Find the right farm work opportunity.</h1>
                <p>Browse open jobs, compare details, and apply quickly to the opportunities that match your skills.</p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4">
        <% if (jobs.length === 0) { %>
            <div class="alert alert-warning mb-0">No jobs available right now.</div>
        <% } else { %>
            <div class="row">
                <% jobs.forEach(job => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-4 full-height-card">
                            <h5 class="mb-3"><%= job.job_title %></h5>

                            <div class="mb-3">
                                <span class="action-pill"><%= job.category %></span>
                                <span class="action-pill blue"><%= job.work_type %></span>
                                <span class="action-pill gold"><%= job.payment_mode %></span>
                            </div>

                            <p class="premium-subtitle"><%= job.description || 'No description provided.' %></p>

                            <p class="job-detail-line"><strong>Location:</strong> <%= job.location %></p>
                            <p class="job-detail-line"><strong>Wage:</strong> ₹<%= job.wage %></p>
                            <p class="job-detail-line"><strong>Start Date:</strong> <%= job.start_date ? job.start_date.toISOString().split('T')[0] : 'N/A' %></p>
                            <p class="job-detail-line"><strong>End Date:</strong> <%= job.end_date ? job.end_date.toISOString().split('T')[0] : 'N/A' %></p>

                            <form action="/worker/apply/<%= job.id %>" method="POST" class="mt-3">
                                <button type="submit" class="btn pretty-btn-green w-100">Apply Now</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>