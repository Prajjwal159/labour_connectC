<%
  /* ── Unified Navbar Partial ───────────────────────────────────────────
     Props (all optional thanks to typeof guards):
       navId      : string  – id attribute on <nav>
       fixed      : bool    – true = position:fixed, false = position:sticky
       navClass   : string  – extra class on <nav>
       active     : string  – key of the active link ('marketplace','jobs','yojanas','dashboard')
       links      : array   – [{key, href, label}]  (falls back to standard links)
       brandHref  : string  – custom brand href

     Auth is read from res.locals.currentUser (set by app.js middleware).
  ── */
  var _navId      = (typeof navId      !== 'undefined' && navId)      ? navId      : '';
  var _fixed      = (typeof fixed      !== 'undefined')               ? fixed      : false;
  var _navClass   = (typeof navClass   !== 'undefined' && navClass)   ? navClass   : '';
  var _active     = (typeof active     !== 'undefined' && active)     ? active     : '';
  var _links      = (typeof links      !== 'undefined' && links)      ? links      : [
      { key: 'marketplace', href: '/marketplace?lang=' + currentLang, label: 'Marketplace' },
      { key: 'jobs',        href: '/worker/jobs?lang=' + currentLang, label: 'Jobs' },
      { key: 'yojanas',     href: '/krishi-yojanas?lang=' + currentLang, label: 'Krishi Yojanas' }
  ];
  var _brandHref  = (typeof brandHref  !== 'undefined' && brandHref)  ? brandHref  : ('/?lang=' + currentLang);
  var _langHref   = '?lang=' + (currentLang === 'en' ? 'kn' : 'en');
  var _langLabel  = currentLang === 'en' ? 'EN' : 'KN';

  /* Auth state from middleware */
  var _user       = (typeof currentUser !== 'undefined') ? currentUser : null;
  var _initial    = _user ? _user.name.trim().charAt(0).toUpperCase() : '';
%>
<nav<% if (_navId) { %> id="<%- _navId %>"<% } %>
    class="nr-unified-nav <%= _fixed ? 'is-fixed' : 'is-sticky' %> <%- _navClass %>"
    role="navigation" aria-label="Main navigation">

  <div class="nr-unified-nav-inner">

    <!-- Brand -->
    <a class="nr-brand" href="<%- _brandHref %>" aria-label="Namma Raitha Home">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A6752"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/>
        <path d="M12 22v-9"/><path d="M12 17l-4-4"/><path d="M12 13l4-4"/>
      </svg>
      <span>Namma Raitha</span>
    </a>

    <!-- Nav Links -->
    <div class="nr-links" role="list">
      <% _links.forEach(function(link) { %>
        <a href="<%- link.href %>"
           class="nr-link <%= _active === link.key ? 'active' : '' %>"
           role="listitem"><%- link.label %></a>
      <% }); %>
    </div>

    <!-- Right actions -->
    <div class="nr-actions">

      <!-- Language toggle -->
      <a href="<%- _langHref %>" class="nr-nav-btn nr-nav-btn-ghost" aria-label="Switch language">
        <%- _langLabel %>
      </a>

      <% if (_user) { %>
        <!-- Logged-in: Avatar with dropdown -->
        <div class="nr-avatar-wrap" id="nr-avatar-wrap">
          <button class="nr-avatar-btn" id="nr-avatar-btn"
                  aria-haspopup="true" aria-expanded="false"
                  aria-label="User menu for <%- _user.name %>">
            <%- _initial %>
          </button>
          <div class="nr-avatar-dropdown" id="nr-avatar-dropdown" role="menu">
            <div class="nr-dropdown-name"><%- _user.name %></div>
            <div class="nr-dropdown-role"><%- _user.role === 'farmer' ? 'Farmer' : 'Worker' %></div>
            <div class="nr-dropdown-divider"></div>
            <a href="<%- _user.dashboardLink %>" class="nr-dropdown-item" role="menuitem">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Dashboard
            </a>
            <a href="/logout?lang=<%- currentLang %>" class="nr-dropdown-item nr-dropdown-logout" role="menuitem">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </a>
          </div>
        </div>
      <% } else { %>
        <!-- Logged-out: Sign In button -->
        <a href="/farmer/login?lang=<%- currentLang %>" class="nr-nav-btn nr-nav-btn-primary">
          Sign In
        </a>
      <% } %>

    </div>
  </div>
</nav>

<style>
/* ── Avatar dropdown ──────────────────────────────────────── */
.nr-avatar-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.nr-avatar-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: #e8f2ea;
  border: 2px solid #b7d9bf;
  color: #2d5a38;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, box-shadow 0.2s;
  line-height: 1;
  padding: 0;
}

.nr-avatar-btn:hover,
.nr-avatar-btn[aria-expanded="true"] {
  background: #c8e6cc;
  box-shadow: 0 0 0 3px rgba(74,103,82,0.18);
  outline: none;
}

.nr-avatar-dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 12px);
  right: 0;
  min-width: 190px;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  box-shadow: 0 16px 40px -8px rgba(0,0,0,0.14);
  padding: 10px 0;
  z-index: 99999;
  animation: nr-dropdown-in 0.18s ease;
}

@keyframes nr-dropdown-in {
  from { opacity: 0; transform: translateY(-6px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

.nr-avatar-dropdown.is-open {
  display: block;
}

.nr-dropdown-name {
  padding: 6px 16px 0;
  font-weight: 700;
  font-size: 0.9rem;
  color: #1a202c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nr-dropdown-role {
  padding: 0 16px 8px;
  font-size: 0.78rem;
  color: #6b7280;
  text-transform: capitalize;
}

.nr-dropdown-divider {
  height: 1px;
  background: #f1f5f9;
  margin: 4px 0;
}

.nr-dropdown-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  font-size: 0.88rem;
  font-weight: 600;
  color: #374151;
  text-decoration: none;
  transition: background 0.15s;
}

.nr-dropdown-item:hover {
  background: #f8faf9;
  color: #2d5a38;
}

.nr-dropdown-logout {
  color: #dc2626;
}

.nr-dropdown-logout:hover {
  background: #fff5f5;
  color: #b91c1c;
}
</style>

<script>
(function() {
  var btn = document.getElementById('nr-avatar-btn');
  var dropdown = document.getElementById('nr-avatar-dropdown');
  if (!btn || !dropdown) return;

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var isOpen = dropdown.classList.contains('is-open');
    dropdown.classList.toggle('is-open', !isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('nr-avatar-wrap');
    if (wrap && !wrap.contains(e.target)) {
      dropdown.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      dropdown.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.focus();
    }
  });
})();
</script>
