<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Marketplace Item</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(20,74,36,0.50), rgba(245,249,244,0.95) 48%, rgba(248,251,247,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2">
            <a href="/marketplace?lang=<%= currentLang %>" class="btn glass-btn">Marketplace</a>
            <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn">Dashboard</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:85vh;">
        <div class="col-lg-7">
            <div class="frost-card p-5">
                <h2 class="text-success fw-bold mb-3">Post Marketplace Item</h2>
                <p class="premium-subtitle mb-4">Add a product, tool, or equipment listing for sale or rent.</p>

                <form action="/farmer/post-marketplace-item?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label>Item Title</label>
                        <input type="text" name="item_title" class="form-control" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Category</label>
                            <select name="category" class="form-select" required>
                                <option value="Vegetables">Vegetables</option>
                                <option value="Fruits">Fruits</option>
                                <option value="Seeds">Seeds</option>
                                <option value="Fertilizers">Fertilizers</option>
                                <option value="Tools">Tools</option>
                                <option value="Equipment">Equipment</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Item Type</label>
                            <select name="item_type" class="form-select" required>
                                <option value="Sell">Sell</option>
                                <option value="Rent">Rent</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Description</label>
                        <textarea name="description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Price</label>
                            <input type="number" step="0.01" name="price" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Location / Village</label>
                            <input type="text" name="location" class="form-control">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Contact Phone</label>
                        <input type="text" name="contact_phone" class="form-control" required>
                    </div>

                    <div class="mb-4">
                        <label>Image URL</label>
                        <input type="text" name="image_url" class="form-control">
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green">Post Item</button>
                        <a href="/marketplace?lang=<%= currentLang %>" class="btn pretty-btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>