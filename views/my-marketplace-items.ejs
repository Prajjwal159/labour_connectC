<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Marketplace Items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<nav class="navbar glass-nav">
  <div class="container d-flex justify-content-between align-items-center">
    <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
    <div class="d-flex gap-2 flex-wrap align-items-center">
      <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn">Dashboard</a>
      <a href="/marketplace?lang=<%= currentLang %>" class="btn glass-btn">Marketplace</a>
      <a href="/worker/jobs?lang=<%= currentLang %>" class="btn glass-btn">Jobs</a>
      <a href="/krishi-yojanas?lang=<%= currentLang %>" class="btn glass-btn">Krishi Yojanas</a>
      <a href="?lang=<%= currentLang === 'en' ? 'kn' : 'en' %>" class="btn glass-btn"><%= currentLang === 'en' ? 'EN' : 'KN' %></a>
      <a href="/logout?lang=<%= currentLang %>" class="btn pretty-btn-green">Logout</a>
    </div>
  </div>
</nav>

<div class="container page-content">
<div class="soft-card p-4 mb-4">
<h2>My Marketplace Items</h2>

<a href="/farmer/post-marketplace-item?lang=<%= currentLang %>" class="btn pretty-btn-green mb-3">+ Post New Item</a>
<a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn pretty-btn-outline mb-3">Back</a>

<% if (items.length === 0) { %>
    <p>No items posted yet.</p>
<% } else { %>
    <% items.forEach(item => { %>
        <div class="card mb-3 p-3">
            <h5><%= item.item_title %></h5>
            <p><strong>Type:</strong> <%= item.item_type %></p>
            <p><strong>Price:</strong> â‚¹<%= item.price %></p>
            <p><strong>Status:</strong> <%= item.status %></p>

            <div class="d-flex gap-2 flex-wrap">
                <a href="/farmer/edit-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" class="btn btn-primary btn-sm">
                    Edit
                </a>

                <% if (item.status === 'Available') { %>
                    <form action="/farmer/mark-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                        <input type="hidden" name="status" value="Sold">
                        <button type="submit" class="btn btn-warning btn-sm">Mark as Sold</button>
                    </form>
                <% } else { %>
                    <form action="/farmer/mark-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                        <input type="hidden" name="status" value="Available">
                        <button type="submit" class="btn btn-success btn-sm">Mark Available</button>
                    </form>
                <% } %>

                <form action="/farmer/delete-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
            </div>
        </div>
    <% }) %>
<% } %>
</div>
</div>

<footer class="platform-footer">
  <div class="row g-4">
    <div class="col-lg-5">
      <a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
      <p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Platform</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/marketplace?lang=<%= currentLang %>">Marketplace</a>
        <a href="/worker/jobs?lang=<%= currentLang %>">Jobs</a>
        <a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Support</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/?lang=<%= currentLang %>">Home</a>
        <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
      </div>
    </div>
    <div class="col-12 col-lg-3">
      <div class="footer-col-title">Legal</div>
      <div class="d-grid gap-2 mt-2">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">(c) 2024 Namma Raitha Digital Ecosystem.</div>
</footer>
</body>
</html>

