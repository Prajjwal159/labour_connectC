<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Marketplace Items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="container mt-4">

<h2>My Marketplace Items</h2>

<a href="/farmer/post-marketplace-item?lang=<%= currentLang %>" class="btn btn-success mb-3">+ Post New Item</a>
<a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn btn-secondary mb-3">Back</a>

<% if (items.length === 0) { %>
    <p>No items posted yet.</p>
<% } else { %>
    <% items.forEach(item => { %>
        <div class="card mb-3 p-3">
            <h5><%= item.item_title %></h5>
            <p><strong>Type:</strong> <%= item.item_type %></p>
            <p><strong>Price:</strong> ₹<%= item.price %></p>
            <p><strong>Status:</strong> <%= item.status %></p>

            <div class="d-flex gap-2 flex-wrap">
                <a href="/farmer/edit-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" class="btn btn-primary btn-sm">
                    Edit
                </a>

                <% if (item.status === 'Available') { %>
                    <form action="/farmer/mark-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                        <input type="hidden" name="status" value="Sold">
                        <button type="submit" class="btn btn-warning btn-sm">Mark as Sold</button>
                    </form>
                <% } else { %>
                    <form action="/farmer/mark-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                        <input type="hidden" name="status" value="Available">
                        <button type="submit" class="btn btn-success btn-sm">Mark Available</button>
                    </form>
                <% } %>

                <form action="/farmer/delete-marketplace-item/<%= item.id %>?lang=<%= currentLang %>" method="POST">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
            </div>
        </div>
    <% }) %>
<% } %>

</body>
</html>