<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('my_applications') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1499529112087-3cb3b73cec95?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(15,50,90,0.45), rgba(245,248,255,0.95) 45%, rgba(248,250,255,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-primary">ಕನ್ನಡ</a>
            <a href="/worker/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('application_tracker') %></div>
                <h1 class="premium-section-title text-white"><%= t('my_applications') %></h1>
                <p><%= t('worker_applications_text') %></p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4">
        <% if (applications.length === 0) { %>
            <div class="alert alert-warning mb-0"><%= t('no_applications_yet') %></div>
        <% } else { %>
            <div class="row">
                <% applications.forEach(app => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-4 full-height-card">
                            <h5 class="mb-3"><%= app.job_title %></h5>

                            <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= app.category %></p>
                            <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= app.location %></p>
                            <p class="job-detail-line"><strong><%= t('wage') %>:</strong> ₹<%= app.wage %></p>

                            <p class="job-detail-line">
                                <strong><%= t('applied_for_version') %>:</strong>
                                <span class="badge bg-info text-dark status-badge"><%= t('version') %> <%= app.job_version %></span>
                            </p>

                            <p class="job-detail-line">
                                <strong><%= t('current_job_version') %>:</strong>
                                <span class="badge bg-secondary status-badge"><%= t('version') %> <%= app.current_job_version %></span>
                            </p>

                            <p class="job-detail-line">
                                <strong><%= t('status') %>:</strong>
                                <% if (app.application_status === 'Applied') { %>
                                    <span class="badge bg-warning text-dark status-badge"><%= t('applied') %></span>
                                <% } else if (app.application_status === 'Accepted') { %>
                                    <span class="badge bg-success status-badge"><%= t('accepted') %></span>
                                <% } else { %>
                                    <span class="badge bg-danger status-badge"><%= t('rejected') %></span>
                                <% } %>
                            </p>

                            <% if (app.job_version < app.current_job_version) { %>
                                <div class="alert alert-info mt-3 mb-0">
                                    <%= t('older_version_application_text') %>
                                </div>
                            <% } else { %>
                                <div class="alert alert-success mt-3 mb-0">
                                    <%= t('latest_version_application_text') %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>