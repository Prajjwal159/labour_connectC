<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('my_applications') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell jobs-ui-page">
<%
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: `/worker/jobs?lang=${currentLang}`, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
  const navActions = [
    { href: `?lang=${currentLang === 'en' ? 'kn' : 'en'}`, label: currentLang === 'en' ? 'EN' : 'KN', className: 'nr-nav-btn nr-nav-btn-ghost' },
    { href: `/worker/dashboard?lang=${currentLang}`, label: 'Dashboard', className: 'nr-nav-btn nr-nav-btn-primary' }
  ];
%>
<%- include('partials/unified-navbar', { navId: 'landingNav', fixed: false, active: 'jobs', links: navLinks, actions: navActions }) %>

<main class="container jobs-page-wrap">
    <section class="jobs-hero-card">
        <h1><%= t('my_applications') %></h1>
        <p><%= t('worker_applications_text') %></p>
    </section>
    <section class="jobs-results-wrap">
        <% if (applications.length === 0) { %>
            <div class="jobs-empty"><%= t('no_applications_yet') %></div>
        <% } else { %>
            <div class="jobs-cards-grid">
                <% applications.forEach(app => { %>
                    <article class="jobs-listing-card">
                        <h5><%= app.job_title %></h5>
                        <p class="job-detail-line"><strong><%= t('category') %>:</strong> <%= app.category %></p>
                        <p class="job-detail-line"><strong><%= t('location') %>:</strong> <%= app.location %></p>
                        <p class="job-detail-line"><strong><%= t('wage') %>:</strong> &#8377;<%= app.wage %></p>
                        <p class="job-detail-line"><strong><%= t('applied_for_version') %>:</strong> <span class="badge bg-info text-dark status-badge"><%= t('version') %> <%= app.job_version %></span></p>
                        <p class="job-detail-line"><strong><%= t('current_job_version') %>:</strong> <span class="badge bg-secondary status-badge"><%= t('version') %> <%= app.current_job_version %></span></p>
                        <p class="job-detail-line">
                            <strong><%= t('status') %>:</strong>
                            <% if (app.application_status === 'Applied') { %>
                                <span class="badge bg-warning text-dark status-badge"><%= t('applied') %></span>
                            <% } else if (app.application_status === 'Accepted') { %>
                                <span class="badge bg-success status-badge"><%= t('accepted') %></span>
                            <% } else { %>
                                <span class="badge bg-danger status-badge"><%= t('rejected') %></span>
                            <% } %>
                        </p>
                        <% if (app.job_version < app.current_job_version) { %>
                            <div class="alert alert-info mt-3 mb-0"><%= t('older_version_application_text') %></div>
                        <% } else { %>
                            <div class="alert alert-success mt-3 mb-0"><%= t('latest_version_application_text') %></div>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>
</main>

<footer class="platform-footer">
  <div class="row g-4">
    <div class="col-lg-5">
      <a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
      <p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Platform</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/marketplace?lang=<%= currentLang %>">Marketplace</a>
        <a href="/worker/jobs?lang=<%= currentLang %>">Jobs</a>
        <a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Support</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/?lang=<%= currentLang %>">Home</a>
        <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
      </div>
    </div>
    <div class="col-12 col-lg-3">
      <div class="footer-col-title">Legal</div>
      <div class="d-grid gap-2 mt-2">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">© 2024 Namma Raitha Digital Ecosystem.</div>
</footer>
</body>
</html>
