<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Applications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1499529112087-3cb3b73cec95?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(15,50,90,0.45), rgba(245,248,255,0.95) 45%, rgba(248,250,255,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/worker/dashboard" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Application Tracker</div>
                <h1 class="premium-section-title text-white">My Applications</h1>
                <p>Track every version of the jobs you applied for and monitor status changes clearly.</p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4">
        <% if (applications.length === 0) { %>
            <div class="alert alert-warning mb-0">You have not applied for any jobs.</div>
        <% } else { %>
            <div class="row">
                <% applications.forEach(app => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-4 full-height-card">
                            <h5 class="mb-3"><%= app.job_title %></h5>

                            <p class="job-detail-line"><strong>Category:</strong> <%= app.category %></p>
                            <p class="job-detail-line"><strong>Location:</strong> <%= app.location %></p>
                            <p class="job-detail-line"><strong>Wage:</strong> ₹<%= app.wage %></p>

                            <p class="job-detail-line">
                                <strong>Applied For Version:</strong>
                                <span class="badge bg-info text-dark status-badge">Version <%= app.job_version %></span>
                            </p>

                            <p class="job-detail-line">
                                <strong>Current Job Version:</strong>
                                <span class="badge bg-secondary status-badge">Version <%= app.current_job_version %></span>
                            </p>

                            <p class="job-detail-line">
                                <strong>Status:</strong>
                                <% if (app.application_status === 'Applied') { %>
                                    <span class="badge bg-warning text-dark status-badge">Applied</span>
                                <% } else if (app.application_status === 'Accepted') { %>
                                    <span class="badge bg-success status-badge">Accepted</span>
                                <% } else { %>
                                    <span class="badge bg-danger status-badge">Rejected</span>
                                <% } %>
                            </p>

                            <% if (app.job_version < app.current_job_version) { %>
                                <div class="alert alert-info mt-3 mb-0">
                                    This application belongs to an older job version. The farmer has updated this job since you applied.
                                </div>
                            <% } else { %>
                                <div class="alert alert-success mt-3 mb-0">
                                    This application belongs to the latest version of the job.
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>