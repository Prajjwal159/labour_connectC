<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Subscription Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>
        <a href="/farmer/register?lang=<%= currentLang %>" class="btn glass-btn">Back</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:85vh;">
        <div class="col-lg-6">
            <div class="frost-card p-5 text-center">
                <h2 class="text-success fw-bold mb-3">Complete Subscription Payment</h2>
                <p class="mb-2"><strong>Selected Plan:</strong> <%= farmerData.subscription_plan_label %></p>
                <p class="mb-4"><strong>Amount:</strong> ₹<%= farmerData.subscription_amount %></p>

                <div class="mb-4">
                    <img
                        src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=DEMO_PAYMENT_<%= farmerData.subscription_amount %>"
                        alt="Demo QR Payment"
                        class="img-fluid"
                        style="border-radius:18px; border:1px solid #ddd;"
                    >
                </div>

                <p class="text-muted mb-4">
                    This is a demo payment page for project presentation.
                </p>

                <form action="/farmer/confirm-payment?lang=<%= currentLang %>" method="POST" class="d-flex justify-content-center gap-2 flex-wrap">
                    <button type="submit" class="btn pretty-btn-green">Complete Demo Payment</button>
                    <a href="/farmer/register?lang=<%= currentLang %>" class="btn pretty-btn-outline">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>