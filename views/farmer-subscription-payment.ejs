<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Subscription Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(17,58,28,0.58), rgba(240,247,238,0.95) 48%, rgba(245,248,242,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>
        <a href="/farmer/register?lang=<%= currentLang %>" class="btn glass-btn">Back</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row justify-content-center align-items-center" style="min-height:85vh;">
        <div class="col-lg-6">
            <div class="frost-card p-5 text-center">
                <h2 class="text-success fw-bold mb-3">Complete Subscription Payment</h2>
                <p class="mb-2"><strong>Selected Plan:</strong> <%= farmerData.subscription_plan_label %></p>
                <p class="mb-4"><strong>Amount:</strong> ₹<%= farmerData.subscription_amount %></p>

                <div class="mb-4">
                    <img
                        src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=<%= encodeURIComponent('http://10.192.195.208:5000/farmer/demo-pay/' + paymentToken + '?lang=' + currentLang) %>"
                        alt="Demo QR Payment"
                        class="img-fluid"
                        style="border-radius:18px; border:1px solid #ddd;"
                    >
                </div>

                <p class="text-muted mb-2">
                    Scan this QR from your phone on the same Wi-Fi.
                </p>

                <p class="text-muted mb-3">
                    After payment is completed on phone, this page will redirect automatically.
                </p>

                <p class="mb-4">
                    <a href="http://10.192.195.208:5000/farmer/demo-pay/<%= paymentToken %>?lang=<%= currentLang %>" target="_blank">
                        Open payment link manually
                    </a>
                </p>

                <div id="paymentStatus" class="alert alert-warning mb-0">
                    Waiting for payment...
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    let paymentHandled = false;

    setInterval(async () => {
        try {
            const res = await fetch("/check-payment-status");
            const data = await res.json();

            const statusBox = document.getElementById("paymentStatus");

            if (data.status === "done" && !paymentHandled) {
                paymentHandled = true;
                statusBox.className = "alert alert-success mb-0";
                statusBox.textContent = "Payment detected. Finalizing account...";

                const confirmRes = await fetch("/farmer/confirm-payment?lang=<%= currentLang %>", {
                    method: "POST"
                });

                const html = await confirmRes.text();
                document.open();
                document.write(html);
                document.close();
            }
        } catch (err) {
            console.log(err);
        }
    }, 2000);
</script>
</body>
</html>