<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= item.item_title %> - Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="b2b-marketplace-page">
<%
  const detailJobsLink = typeof jobsPortalLink !== "undefined"
    ? jobsPortalLink
    : `/worker/jobs?lang=${currentLang}`;
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: detailJobsLink, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
  const navActions = [
    { href: `?lang=${currentLang === 'en' ? 'kn' : 'en'}`, label: currentLang === 'en' ? 'EN' : 'KN', className: 'nr-nav-btn nr-nav-btn-ghost' },
    { href: `/farmer/post-marketplace-item?lang=${currentLang}`, label: 'Post Item', className: 'nr-nav-btn nr-nav-btn-primary' }
  ];
%>
<%- include('partials/unified-navbar', { fixed: false, active: 'marketplace', links: navLinks, actions: navActions }) %>

<section class="b2b-detail-wrap">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-7">
                <div class="b2b-detail-media-card">
                    <% if (item.image_url) { %>
                        <img src="<%= item.image_url %>" alt="<%= item.item_title %>" class="b2b-detail-main-image">
                    <% } else { %>
                        <div class="b2b-detail-image-fallback">No Image Available</div>
                    <% } %>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="b2b-detail-info-card">
                    <div class="b2b-detail-head">
                        <h1><%= item.item_title %></h1>
                        <span class="b2b-status-badge"><%= item.status %></span>
                    </div>

                    <div class="b2b-pill-row mb-3">
                        <span class="b2b-pill"><%= item.category %></span>
                        <span class="b2b-pill b2b-pill-blue"><%= item.item_type %></span>
                    </div>

                    <p class="b2b-detail-price">₹<%= item.price %></p>

                    <div class="b2b-detail-lines">
                        <p><strong>Description:</strong> <%= item.description || 'No description provided.' %></p>
                        <p><strong>Location:</strong> <%= item.location || 'N/A' %></p>
                        <p><strong>Seller:</strong> <%= item.full_name %></p>
                        <p><strong>Contact:</strong> <%= item.contact_phone || 'N/A' %></p>
                    </div>

                    <div class="b2b-detail-actions">
                        <a href="tel:<%= item.contact_phone %>" class="btn b2b-btn-primary">Contact Seller</a>
                        <a href="https://wa.me/91<%= item.contact_phone %>" target="_blank" class="btn b2b-btn-outline">WhatsApp Seller</a>
                        <a href="/marketplace?lang=<%= currentLang %>" class="btn b2b-btn-outline">Back to Marketplace</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

</body>
</html>

