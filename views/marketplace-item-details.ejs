<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= item.item_title %> - Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(20,74,36,0.48), rgba(245,249,244,0.96) 48%, rgba(248,251,247,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2 flex-wrap">
            <a href="/marketplace?lang=<%= currentLang %>" class="btn glass-btn">Marketplace</a>
            <a href="/?lang=<%= currentLang %>" class="btn glass-btn">Home</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <div class="soft-card p-3">
                <% if (item.image_url) { %>
                    <img src="<%= item.image_url %>" alt="<%= item.item_title %>" class="img-fluid rounded" style="width:100%; max-height:450px; object-fit:cover;">
                <% } else { %>
                    <div class="d-flex align-items-center justify-content-center rounded" style="height:450px; background:#eef5ee; font-size:1.3rem; font-weight:600; color:#4b6b4b;">
                        No Image Available
                    </div>
                <% } %>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="soft-card p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h2 class="mb-0"><%= item.item_title %></h2>
                    <span class="badge bg-success"><%= item.status %></span>
                </div>

                <div class="mb-3">
                    <span class="action-pill"><%= item.category %></span>
                    <span class="action-pill blue"><%= item.item_type %></span>
                </div>

                <h3 class="text-success mb-3">₹<%= item.price %></h3>

                <p class="job-detail-line"><strong>Description:</strong> <%= item.description || 'No description provided.' %></p>
                <p class="job-detail-line"><strong>Location:</strong> <%= item.location || 'N/A' %></p>
                <p class="job-detail-line"><strong>Seller:</strong> <%= item.full_name %></p>
                <p class="job-detail-line"><strong>Contact:</strong> <%= item.contact_phone || 'N/A' %></p>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a href="tel:<%= item.contact_phone %>" class="btn pretty-btn-green">
                        Contact Seller
                    </a>

                    <a href="https://wa.me/91<%= item.contact_phone %>" target="_blank" class="btn pretty-btn-outline">
                        WhatsApp Seller
                    </a>

                    <a href="/marketplace?lang=<%= currentLang %>" class="btn pretty-btn-outline">
                        Back to Marketplace
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>