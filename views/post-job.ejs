<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('post_job') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(90deg, rgba(20,74,36,0.58), rgba(44,128,72,0.18), rgba(255,255,255,0.05));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 <%= t('app_name') %></a>

        <div class="d-flex gap-2 flex-wrap">
            <a href="?lang=en" class="btn btn-sm btn-light">English</a>
            <a href="?lang=kn" class="btn btn-sm btn-success">ಕನ್ನಡ</a>
            <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn glass-btn"><%= t('dashboard') %></a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center" style="min-height:82vh;">
        <div class="col-lg-5">
            <div class="page-hero-text">
                <div class="tag-chip"><%= t('create_new_opportunity') %></div>
                <h1 class="premium-section-title text-white"><%= t('post_job_hero') %></h1>
                <p><%= t('post_job_text') %></p>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="frost-card p-4 pretty-form">
                <h3 class="mb-2 text-success fw-bold"><%= t('post_new_job') %></h3>
                <p class="premium-subtitle mb-4"><%= t('post_job_subtitle') %></p>

                <form action="/farmer/post-job?lang=<%= currentLang %>" method="POST">
                    <div class="mb-3">
                        <label><%= t('job_title') %></label>
                        <input type="text" name="job_title" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label><%= t('workers_required') %></label>
                        <input type="number" name="workers_required" class="form-control" min="1" required>
                    </div>
                    <div class="mb-3">
                        <label><%= t('category') %></label>
                        <select name="category" class="form-select" required>
                            <option value="Ploughing"><%= t('ploughing') %></option>
                            <option value="Planting"><%= t('planting') %></option>
                            <option value="Harvesting"><%= t('harvesting') %></option>
                            <option value="Irrigation"><%= t('irrigation') %></option>
                            <option value="Tractor Driving"><%= t('tractor_driving') %></option>
                            <option value="Dairy Work"><%= t('dairy_work') %></option>
                            <option value="Farm Maintenance"><%= t('farm_maintenance') %></option>
                            <option value="Loading and Packaging"><%= t('loading_packaging') %></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label><%= t('work_type') %></label>
                        <select name="work_type" class="form-select" required>
                            <option value="Hourly"><%= t('hourly') %></option>
                            <option value="Daily"><%= t('daily') %></option>
                            <option value="Weekly"><%= t('weekly') %></option>
                            <option value="Monthly"><%= t('monthly') %></option>
                            <option value="Seasonal"><%= t('seasonal') %></option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label><%= t('description') %></label>
                        <textarea name="description" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label><%= t('location') %></label>
                        <input type="text" name="location" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('wage') %> (₹)</label>
                        <input type="number" name="wage" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label><%= t('payment_mode') %></label>
                        <select name="payment_mode" class="form-select" required>
                            <option value="Cash"><%= t('cash') %></option>
                            <option value="UPI">UPI</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label><%= t('start_date') %></label>
                            <input type="date" name="start_date" class="form-control">
                        </div>
                        <div class="col-md-6 mb-4">
                            <label><%= t('end_date') %></label>
                            <input type="date" name="end_date" class="form-control">
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green"><%= t('post_job') %></button>
                        <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn pretty-btn-outline"><%= t('back') %></a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>