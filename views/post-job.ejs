<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Job</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(90deg, rgba(20,74,36,0.58), rgba(44,128,72,0.18), rgba(255,255,255,0.05));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <a href="/farmer/dashboard" class="btn glass-btn">Dashboard</a>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center" style="min-height:82vh;">
        <div class="col-lg-5">
            <div class="page-hero-text">
                <div class="tag-chip">Create New Opportunity</div>
                <h1 class="premium-section-title text-white">Post an agricultural job with clear details.</h1>
                <p>Describe the work, set wage and duration, and connect with the right worker faster.</p>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="frost-card p-4 pretty-form">
                <h3 class="mb-2 text-success fw-bold">Post a New Job</h3>
                <p class="premium-subtitle mb-4">Fill in the job details carefully for better worker matching.</p>

                <form action="/farmer/post-job" method="POST">
                    <div class="mb-3">
                        <label>Job Title</label>
                        <input type="text" name="job_title" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Category</label>
                        <select name="category" class="form-select" required>
                            <option>Ploughing</option>
                            <option>Planting</option>
                            <option>Harvesting</option>
                            <option>Irrigation</option>
                            <option>Tractor Driving</option>
                            <option>Dairy Work</option>
                            <option>Farm Maintenance</option>
                            <option>Loading and Packaging</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Work Type</label>
                        <select name="work_type" class="form-select" required>
                            <option>Hourly</option>
                            <option>Daily</option>
                            <option>Weekly</option>
                            <option>Monthly</option>
                            <option>Seasonal</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Description</label>
                        <textarea name="description" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>Location</label>
                        <input type="text" name="location" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Wage (₹)</label>
                        <input type="number" name="wage" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Payment Mode</label>
                        <select name="payment_mode" class="form-select" required>
                            <option>Cash</option>
                            <option>UPI</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Start Date</label>
                            <input type="date" name="start_date" class="form-control">
                        </div>
                        <div class="col-md-6 mb-4">
                            <label>End Date</label>
                            <input type="date" name="end_date" class="form-control">
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn pretty-btn-green">Post Job</button>
                        <a href="/farmer/dashboard" class="btn pretty-btn-outline">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
</body>
</html>