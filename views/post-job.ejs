<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('post_job') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell jobs-ui-page">
<%
  const navLinks = [
    { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
    { key: 'jobs', href: `/farmer/jobs?lang=${currentLang}`, label: 'Jobs' },
    { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
  ];
  const navActions = [
    { href: `?lang=${currentLang === 'en' ? 'kn' : 'en'}`, label: currentLang === 'en' ? 'EN' : 'KN', className: 'nr-nav-btn nr-nav-btn-ghost' },
    { href: `/farmer/dashboard?lang=${currentLang}`, label: 'Dashboard', className: 'nr-nav-btn nr-nav-btn-primary' }
  ];
%>
<%- include('partials/unified-navbar', { navId: 'landingNav', fixed: false, active: 'jobs', links: navLinks, actions: navActions }) %>

<main class="container jobs-page-wrap">
    <section class="jobs-wizard-head">
        <h1><%= t('post_job_hero') %></h1>
        <p><%= t('post_job_text') %></p>
    </section>
    <section class="jobs-wizard-grid">
        <aside class="jobs-stepper-card">
            <div class="jobs-step active"><span>1</span> Job Details</div>
            <div class="jobs-step"><span>2</span> Requirements</div>
            <div class="jobs-step"><span>3</span> Review & Post</div>
            <div class="jobs-help-card">
                <h6>Need help?</h6>
                <p>Call our farmer helpline for posting support.</p>
                <strong>1800-NAMMA-RAITHA</strong>
            </div>
        </aside>
        <section class="jobs-form-shell">
            <div class="jobs-form-head">
                <h3><%= t('post_new_job') %></h3>
                <p><%= t('post_job_subtitle') %></p>
            </div>
            <form action="/farmer/post-job?lang=<%= currentLang %>" method="POST" class="jobs-premium-form">
                <div class="mb-3">
                    <label><%= t('job_title') %></label>
                    <input type="text" name="job_title" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label><%= t('workers_required') %></label>
                    <input type="number" name="workers_required" class="form-control" min="1" required>
                </div>
                <div class="mb-3">
                    <label><%= t('category') %></label>
                    <select name="category" class="form-select" required>
                        <option value="Ploughing"><%= t('ploughing') %></option>
                        <option value="Planting"><%= t('planting') %></option>
                        <option value="Harvesting"><%= t('harvesting') %></option>
                        <option value="Irrigation"><%= t('irrigation') %></option>
                        <option value="Tractor Driving"><%= t('tractor_driving') %></option>
                        <option value="Dairy Work"><%= t('dairy_work') %></option>
                        <option value="Farm Maintenance"><%= t('farm_maintenance') %></option>
                        <option value="Loading and Packaging"><%= t('loading_packaging') %></option>
                    </select>
                </div>
                <div class="mb-3">
                    <label><%= t('work_type') %></label>
                    <select name="work_type" class="form-select" required>
                        <option value="Hourly"><%= t('hourly') %></option>
                        <option value="Daily"><%= t('daily') %></option>
                        <option value="Weekly"><%= t('weekly') %></option>
                        <option value="Monthly"><%= t('monthly') %></option>
                        <option value="Seasonal"><%= t('seasonal') %></option>
                    </select>
                </div>
                <div class="mb-3">
                    <label><%= t('description') %></label>
                    <textarea name="description" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label><%= t('location') %></label>
                    <input type="text" name="location" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label><%= t('wage') %> (&#8377;)</label>
                    <input type="number" name="wage" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label><%= t('payment_mode') %></label>
                    <select name="payment_mode" class="form-select" required>
                        <option value="Cash"><%= t('cash') %></option>
                        <option value="UPI">UPI</option>
                    </select>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label><%= t('start_date') %></label>
                        <input type="date" name="start_date" class="form-control">
                    </div>
                    <div class="col-md-6 mb-4">
                        <label><%= t('end_date') %></label>
                        <input type="date" name="end_date" class="form-control">
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn pretty-btn-green"><%= t('post_job') %></button>
                    <a href="/farmer/dashboard?lang=<%= currentLang %>" class="btn pretty-btn-outline"><%= t('back') %></a>
                </div>
            </form>
        </section>
    </section>
</main>

<footer class="platform-footer">
  <div class="row g-4">
    <div class="col-lg-5">
      <a class="footer-brand" href="/?lang=<%= currentLang %>">Namma Raitha</a>
      <p class="footer-mini">Empowering sustainable agriculture through technology, jobs, and trusted marketplace access.</p>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Platform</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/marketplace?lang=<%= currentLang %>">Marketplace</a>
        <a href="/farmer/dashboard?lang=<%= currentLang %>">Jobs</a>
        <a href="/krishi-yojanas?lang=<%= currentLang %>">Krishi Yojanas</a>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="footer-col-title">Support</div>
      <div class="d-grid gap-2 mt-2">
        <a href="/?lang=<%= currentLang %>">Home</a>
        <a href="/farmer/login?lang=<%= currentLang %>">Login</a>
      </div>
    </div>
    <div class="col-12 col-lg-3">
      <div class="footer-col-title">Legal</div>
      <div class="d-grid gap-2 mt-2">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">© 2024 Namma Raitha Digital Ecosystem.</div>
</footer>
</body>
</html>

