<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Worker Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1464226184884-fa280b87c399?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(10,44,82,0.5), rgba(239,246,255,0.94) 50%, rgba(245,249,255,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2">
            <a href="/worker/jobs" class="btn glass-btn">Jobs</a>
            <a href="/logout" class="btn glass-btn-outline">Logout</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <div class="page-hero-text">
                <div class="tag-chip">Worker Opportunity Hub</div>
                <h1 class="premium-section-title text-white">Welcome, <%= worker.full_name %></h1>
                <p>Explore agricultural work, apply faster, and monitor every application from one clean dashboard.</p>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="visual-card" style="height:260px;">
                <img src="https://images.unsplash.com/photo-1500651230702-0e2d8a49d4ad?auto=format&fit=crop&w=1200&q=80" alt="Worker in field">
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="metric-card metric-blue">
                <h5>Skill Category</h5>
                <h2 style="font-size:1.4rem;"><%= worker.skill_category || 'N/A' %></h2>
                <p class="mb-0">Primary work type you are best suited for.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-green">
                <h5>Experience</h5>
                <h2><%= worker.experience_level || 'N/A' %></h2>
                <p class="mb-0">Your current experience level for recruiters.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card metric-gold">
                <h5>Village</h5>
                <h2><%= worker.village || 'N/A' %></h2>
                <p class="mb-0">Your local area for nearby agricultural work.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="soft-card p-4 full-height-card">
                <h4 class="mb-3">Worker Profile</h4>
                <p class="job-detail-line"><strong>Name:</strong> <%= worker.full_name %></p>
                <p class="job-detail-line"><strong>Email:</strong> <%= worker.email %></p>
                <p class="job-detail-line"><strong>Phone:</strong> <%= worker.phone %></p>
                <p class="job-detail-line"><strong>Village:</strong> <%= worker.village || 'N/A' %></p>
                <p class="job-detail-line"><strong>Skill:</strong> <%= worker.skill_category || 'N/A' %></p>
                <p class="job-detail-line"><strong>Experience:</strong> <%= worker.experience_level || 'N/A' %></p>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="soft-card p-4 full-height-card">
                <h4 class="mb-3">Quick Actions</h4>
                <p class="premium-subtitle mb-4">Move through the platform quickly using these shortcuts.</p>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="soft-card p-4 text-center full-height-card">
                            <h5>Browse Jobs</h5>
                            <p class="premium-subtitle">Find available farm work based on your skills and availability.</p>
                            <a href="/worker/jobs" class="btn pretty-btn-blue w-100">View Available Jobs</a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="soft-card p-4 text-center full-height-card">
                            <h5>My Applications</h5>
                            <p class="premium-subtitle">Check which jobs you applied for and see the latest status.</p>
                            <a href="/worker/my-applications" class="btn pretty-btn-outline w-100">My Applications</a>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <span class="action-pill blue">Jobs</span>
                    <span class="action-pill">Applications</span>
                    <span class="action-pill gold">Rural Work</span>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>