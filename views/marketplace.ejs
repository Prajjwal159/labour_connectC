<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="b2b-marketplace-page">
<%
    const jobsLink = typeof jobsPortalLink !== "undefined"
        ? jobsPortalLink
        : `/marketplace?lang=${currentLang}`;
    const navLinks = [
        { key: 'marketplace', href: `/marketplace?lang=${currentLang}`, label: 'Marketplace' },
        { key: 'jobs', href: jobsLink, label: 'Jobs' },
        { key: 'yojanas', href: `/krishi-yojanas?lang=${currentLang}`, label: 'Krishi Yojanas' }
    ];
%>
<%- include('partials/unified-navbar', { fixed: false, active: 'marketplace', links: navLinks }) %>

<section class="b2b-market-hero">
    <div class="container">
        <div class="b2b-hero-card">
            <h1>Discover Agricultural Excellence</h1>
            <p>Connect directly with trusted sellers, compare listings, and contact suppliers across Karnataka.</p>

            <form action="/marketplace" method="GET" class="b2b-hero-search-row">
                <input type="hidden" name="lang" value="<%= currentLang %>">
                <input type="text" name="keyword" class="form-control" placeholder="Search by title" value="<%= filters.keyword %>">
                <button type="submit" class="btn">Search</button>
            </form>
        </div>
    </div>
</section>

<div class="container b2b-market-layout">
    <div class="row g-4 align-items-start">
        <aside class="col-lg-3">
            <div class="b2b-filter-card">
                <div class="b2b-filter-head">
                    <h2>Filters</h2>
                </div>

                <form action="/marketplace" method="GET" class="b2b-filter-form">
                    <input type="hidden" name="lang" value="<%= currentLang %>">
                    <input type="hidden" name="keyword" value="<%= filters.keyword %>">

                    <div class="b2b-filter-block">
                        <label>Category</label>
                        <select name="category" class="form-select">
                            <option value="">All Categories</option>
                            <option value="Vegetables" <%= filters.category === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
                            <option value="Fruits" <%= filters.category === 'Fruits' ? 'selected' : '' %>>Fruits</option>
                            <option value="Seeds" <%= filters.category === 'Seeds' ? 'selected' : '' %>>Seeds</option>
                            <option value="Fertilizers" <%= filters.category === 'Fertilizers' ? 'selected' : '' %>>Fertilizers</option>
                            <option value="Tools" <%= filters.category === 'Tools' ? 'selected' : '' %>>Tools</option>
                            <option value="Equipment" <%= filters.category === 'Equipment' ? 'selected' : '' %>>Equipment</option>
                            <option value="Other" <%= filters.category === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </div>

                    <div class="b2b-filter-block">
                        <label>Type</label>
                        <select name="item_type" class="form-select">
                            <option value="">Sell / Rent</option>
                            <option value="Sell" <%= filters.item_type === 'Sell' ? 'selected' : '' %>>Sell</option>
                            <option value="Rent" <%= filters.item_type === 'Rent' ? 'selected' : '' %>>Rent</option>
                        </select>
                    </div>

                    <div class="b2b-filter-block">
                        <label>Min Price</label>
                        <input type="number" step="0.01" name="min_price" class="form-control" placeholder="Min Price" value="<%= filters.min_price %>">
                    </div>

                    <div class="b2b-filter-block">
                        <label>Max Price</label>
                        <input type="number" step="0.01" name="max_price" class="form-control" placeholder="Max Price" value="<%= filters.max_price %>">
                    </div>

                    <div class="b2b-filter-block">
                        <label>Location / Village</label>
                        <input type="text" name="location" class="form-control" placeholder="Location / Village" value="<%= filters.location %>">
                    </div>

                    <button type="submit" class="btn b2b-filter-submit">Apply Filters</button>
                </form>
            </div>
        </aside>

        <section class="col-lg-9">
            <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'farmer') { %>
            <div style="display:flex; align-items:center; justify-content:space-between; background:#f0f7f1; border:1.5px solid #c6deca; border-radius:14px; padding:16px 22px; margin-bottom:20px; gap:12px; flex-wrap:wrap;">
                <div>
                    <p style="margin:0; font-weight:700; color:#2d4a35; font-size:0.95rem;">Have produce or supplies to sell?</p>
                    <p style="margin:0; font-size:0.82rem; color:#5a7a63;">List your item and reach buyers across Karnataka directly.</p>
                </div>
                <a href="/farmer/add-marketplace-item?lang=<%= currentLang %>" class="btn" style="background:#3d5c44; color:#fff; border-radius:10px; padding:10px 22px; font-weight:700; font-size:0.9rem; text-decoration:none; white-space:nowrap; flex-shrink:0; box-shadow:0 4px 12px rgba(61,92,68,0.25);">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:5px; vertical-align:middle;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Post an Item
                </a>
            </div>
            <% } %>
            <div class="b2b-result-head">
                <p>
                    Showing <strong><%= items.length %></strong> result<%= items.length === 1 ? '' : 's' %>
                    <% if (filters.keyword) { %>
                        for "<%= filters.keyword %>"
                    <% } %>
                </p>
            </div>

            <% if (items.length === 0) { %>
                <div class="b2b-empty-state">No marketplace items available right now.</div>
            <% } else { %>
                <div class="row g-4">
                    <% items.forEach(item => { %>
                        <div class="col-md-6 col-xl-4">
                            <article class="b2b-product-card">
                                <a href="/marketplace/item/<%= item.id %>?lang=<%= currentLang %>" class="b2b-product-image-wrap">
                                    <% if (item.image_url) { %>
                                        <img src="<%= item.image_url %>" alt="<%= item.item_title %>">
                                    <% } else { %>
                                        <div class="b2b-product-image-fallback">No Image Available</div>
                                    <% } %>
                                    <span class="b2b-status-badge"><%= item.status %></span>
                                </a>

                                <div class="b2b-product-body">
                                    <h3><%= item.item_title %></h3>
                                    <div class="b2b-pill-row">
                                        <span class="b2b-pill"><%= item.category %></span>
                                        <span class="b2b-pill b2b-pill-blue"><%= item.item_type %></span>
                                    </div>

                                    <p class="b2b-product-meta"><strong>Seller:</strong> <%= item.full_name %></p>
                                    <p class="b2b-product-meta"><strong>Location:</strong> <%= item.location || 'N/A' %></p>
                                    <p class="b2b-product-price">₹<%= item.price %></p>

                                    <div class="b2b-card-actions">
                                        <a href="/marketplace/item/<%= item.id %>?lang=<%= currentLang %>" class="btn b2b-btn-primary">View Details</a>
                                        <a href="tel:<%= item.contact_phone %>" class="btn b2b-btn-outline">Contact Seller</a>
                                    </div>
                                </div>
                            </article>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </div>
</div>


<%- include('partials/micro-interactions') %>
</body>
</html>

