<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
<div class="page-bg" style="background-image:url('https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&w=1600&q=80');"></div>
<div class="page-overlay" style="background:linear-gradient(180deg, rgba(20,74,36,0.48), rgba(245,249,244,0.96) 48%, rgba(248,251,247,1));"></div>

<nav class="navbar glass-nav">
    <div class="container">
        <a class="navbar-brand glass-brand" href="/?lang=<%= currentLang %>">🌾 Namma Raitha Jobs</a>
        <div class="d-flex gap-2 flex-wrap">
            <a href="/?lang=<%= currentLang %>" class="btn glass-btn">Home</a>
            <a href="/farmer/post-marketplace-item?lang=<%= currentLang %>" class="btn glass-btn">Post Item</a>
        </div>
    </div>
</nav>

<div class="container page-content">
    <div class="row align-items-center mb-4">
        <div class="col-lg-8">
            <div class="page-hero-text">
                <div class="tag-chip">Farmer Marketplace</div>
                <h1 class="premium-section-title text-white">Buy, sell, or rent farming products and tools.</h1>
                <p>Explore market listings from farmers and rural communities in one place.</p>
            </div>
        </div>
    </div>

    <div class="soft-card p-4 mb-4">
        <form action="/marketplace" method="GET" class="row g-3">
            <input type="hidden" name="lang" value="<%= currentLang %>">

            <div class="col-md-3">
                <input type="text" name="keyword" class="form-control" placeholder="Search by title" value="<%= filters.keyword %>">
            </div>

            <div class="col-md-2">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <option value="Vegetables" <%= filters.category === 'Vegetables' ? 'selected' : '' %>>Vegetables</option>
                    <option value="Fruits" <%= filters.category === 'Fruits' ? 'selected' : '' %>>Fruits</option>
                    <option value="Seeds" <%= filters.category === 'Seeds' ? 'selected' : '' %>>Seeds</option>
                    <option value="Fertilizers" <%= filters.category === 'Fertilizers' ? 'selected' : '' %>>Fertilizers</option>
                    <option value="Tools" <%= filters.category === 'Tools' ? 'selected' : '' %>>Tools</option>
                    <option value="Equipment" <%= filters.category === 'Equipment' ? 'selected' : '' %>>Equipment</option>
                    <option value="Other" <%= filters.category === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
            </div>

            <div class="col-md-2">
                <select name="item_type" class="form-select">
                    <option value="">Sell / Rent</option>
                    <option value="Sell" <%= filters.item_type === 'Sell' ? 'selected' : '' %>>Sell</option>
                    <option value="Rent" <%= filters.item_type === 'Rent' ? 'selected' : '' %>>Rent</option>
                </select>
            </div>

            <div class="col-md-2">
                <input type="number" step="0.01" name="min_price" class="form-control" placeholder="Min Price" value="<%= filters.min_price %>">
            </div>

            <div class="col-md-2">
                <input type="number" step="0.01" name="max_price" class="form-control" placeholder="Max Price" value="<%= filters.max_price %>">
            </div>

            <div class="col-md-3">
                <input type="text" name="location" class="form-control" placeholder="Location / Village" value="<%= filters.location %>">
            </div>

            <div class="col-md-3">
                <button type="submit" class="btn pretty-btn-green w-100">Filter</button>
            </div>
        </form>
    </div>

    <div class="soft-card p-4">
        <% if (items.length === 0) { %>
            <div class="alert alert-warning mb-0">No marketplace items available right now.</div>
        <% } else { %>
            <div class="row">
                <% items.forEach(item => { %>
                    <div class="col-md-6 mb-4">
                        <div class="soft-card p-3 full-height-card">
                            <% if (item.image_url) { %>
                                <img src="<%= item.image_url %>" alt="<%= item.item_title %>" class="img-fluid rounded mb-3" style="height:220px; width:100%; object-fit:cover;">
                            <% } else { %>
                                <div class="d-flex align-items-center justify-content-center rounded mb-3" style="height:220px; width:100%; background:#eef5ee; font-size:1.2rem; font-weight:600; color:#4b6b4b;">
                                    No Image Available
                                </div>
                            <% } %>

                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="mb-0"><%= item.item_title %></h5>
                                <span class="badge bg-success"><%= item.status %></span>
                            </div>

                            <div class="mb-2">
                                <span class="action-pill"><%= item.category %></span>
                                <span class="action-pill blue"><%= item.item_type %></span>
                            </div>

                            <p class="premium-subtitle"><%= item.description || 'No description provided.' %></p>
                            <p class="job-detail-line"><strong>Price:</strong> ₹<%= item.price %></p>
                            <p class="job-detail-line"><strong>Location:</strong> <%= item.location || 'N/A' %></p>
                            <p class="job-detail-line"><strong>Contact:</strong> <%= item.contact_phone || 'N/A' %></p>
                            <p class="job-detail-line"><strong>Seller:</strong> <%= item.full_name %></p>

                            <a href="tel:<%= item.contact_phone %>" class="btn pretty-btn-green w-100 mt-2">
                                Contact Seller
                            </a>

                            <a href="https://wa.me/91<%= item.contact_phone %>" target="_blank" class="btn pretty-btn-outline w-100 mt-2">
                                WhatsApp Seller
                            </a>
                            <a href="/marketplace/item/<%= item.id %>?lang=<%= currentLang %>" class="btn pretty-btn-blue w-100 mt-2">
                                View Details
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
</body>
</html>